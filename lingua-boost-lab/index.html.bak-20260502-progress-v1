<script>
(function () {
  function applyLang(lang) {
    var next = lang === "en" ? "en" : "ru";
    document.documentElement.setAttribute("lang", next);
    document.querySelectorAll("[data-ru][data-en]").forEach(function (node) {
      var value = node.getAttribute(next === "en" ? "data-en" : "data-ru");
      if (value == null) return;
      if (node.getAttribute("data-i18n-mode") === "html") {
        node.innerHTML = value;
      } else {
        node.textContent = value;
      }
    });
    var button = document.getElementById("langBtn");
    if (button) button.textContent = next.toUpperCase();
    try { localStorage.setItem("nge-lang", next); } catch (error) {}
  }

  window.toggleLang = function () {
    applyLang((document.documentElement.getAttribute("lang") || "ru") === "ru" ? "en" : "ru");
  };

  document.addEventListener("DOMContentLoaded", function () {
    var stored = "ru";
    try { stored = localStorage.getItem("nge-lang") || "ru"; } catch (error) {}
    applyLang(stored);
    var button = document.getElementById("langBtn");
    if (button && button.dataset.langBound !== "true") {
      button.dataset.langBound = "true";
      button.addEventListener("click", window.toggleLang);
    }
  });
})();
</script>

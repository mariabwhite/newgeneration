<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<link rel="icon" href="../assets/linguaboost-lab-favicon.svg" type="image/svg+xml">
<meta name="description" content="LinguaBoost Studio — понятная библиотека интерактивных модулей по английскому: от первых слов до уверенной практики.">
<title>LinguaBoost Studio | Библиотека модулей</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;800;900&family=Manrope:wght@400;500;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ── Midnight Plum В· NGE Design System ── */
:root {
  --bg:        #0e0a18;
  --bg-2:      #120c1d;
  --bg-card:   #1a1326;
  --bg-card-2: #21172f;
  --plum:      #9a7ad9;
  --plum-2:    #c5aef0;
  --accent:    #ff9b2f;
  --success:   #2ee59d;
  --text:      #f0ebff;
  --muted:     #bfaee0;
  --faint:     #8f7daa;
  --line:      rgba(197,174,240,0.12);
  --line-2:    rgba(197,174,240,0.22);
  --line-dot:  rgba(154,122,217,0.35);
  --topbar-bg: rgba(14,10,24,0.92);
  --module-bg: rgba(12,8,20,0.72);
  --bg-radial-1: rgba(154,122,217,0.22);
  --bg-radial-2: rgba(255,155,47,0.08);
  --bg-radial-3: rgba(154,122,217,0.12);
  --hero-glow: rgba(154,122,217,0.16);
  --title-glow: rgba(154,122,217,0.28);
  --title-accent-shadow: rgba(154,122,217,0.44);
  --quick-hover: rgba(154,122,217,0.08);
  --accent-soft: rgba(255,155,47,0.08);
  --accent-soft-2: rgba(255,155,47,0.16);
  --accent-border: rgba(255,155,47,0.36);
  --accent-on: #160b05;
  --accent-hover: #ffb055;
  --accent-hover-text: #ffd090;
  --ghost-stroke: rgba(154,122,217,0.26);
  --ghost-fill: rgba(154,122,217,0.05);
  --mono:      "JetBrains Mono", Consolas, monospace;
  --display:   "Unbounded", "Manrope", system-ui, sans-serif;
  --body-font: "Manrope", system-ui, sans-serif;
}

[data-theme="light"] {
  --bg:        #f7f5ff;
  --bg-2:      #f0ecff;
  --bg-card:   #ffffff;
  --bg-card-2: #f2eeff;
  --text:      #1a1326;
  --muted:     #5f5a70;
  --faint:     #756d86;
  --plum:      #7a5fcf;
  --plum-2:    #4f3ea5;
  --accent:    #ff5a1f;
  --line:      rgba(122,95,207,0.18);
  --line-2:    rgba(122,95,207,0.30);
  --line-dot:  rgba(122,95,207,0.42);
  --topbar-bg: rgba(247,245,255,0.92);
  --module-bg: rgba(255,255,255,0.78);
  --bg-radial-1: rgba(122,95,207,0.22);
  --bg-radial-2: rgba(255,90,31,0.10);
  --bg-radial-3: rgba(122,95,207,0.14);
  --hero-glow: rgba(122,95,207,0.14);
  --title-glow: rgba(122,95,207,0.18);
  --title-accent-shadow: rgba(122,95,207,0.32);
  --quick-hover: rgba(122,95,207,0.10);
  --accent-soft: rgba(255,90,31,0.10);
  --accent-soft-2: rgba(255,90,31,0.18);
  --accent-border: rgba(255,90,31,0.38);
  --accent-on: #1a1326;
  --accent-hover: #ff6d38;
  --accent-hover-text: #b43a0e;
  --ghost-stroke: rgba(122,95,207,0.24);
  --ghost-fill: rgba(122,95,207,0.07);
}

* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: var(--body-font);
  color: var(--text);
  background:
    radial-gradient(circle at 76% 4%,  var(--bg-radial-1), transparent 34%),
    radial-gradient(circle at 12% 36%, var(--bg-radial-2), transparent 28%),
    radial-gradient(circle at 88% 74%, var(--bg-radial-3), transparent 34%),
    var(--bg);
  min-height: 100vh;
}

a   { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
h1, h2, h3 { margin: 0; }

/* Topbar */
.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 1.5rem;
  height: 64px;
  padding: 0 28px;
  background: var(--topbar-bg);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
  flex: 0 0 auto;
}

.brand-logo {
  display: block;
  width: auto;
  height: 38px;
  max-width: min(218px, 34vw);
  object-fit: contain;
}

.brand-logo-light {
  display: none;
}

[data-theme="light"] .brand-logo-dark {
  display: none;
}

[data-theme="light"] .brand-logo-light {
  display: block;
}

.brand-mark {
  width: 34px;
  height: 34px;
  flex: 0 0 34px;
  border: 1px solid rgba(255,155,47,0.38);
  border-radius: 8px;
  background:
    rgba(255,155,47,0.08)
    url("./assets/linguaboost-drop-orange.svg")
    center / 18px 23px no-repeat;
}

[data-theme="light"] .brand-mark {
  border-color: rgba(168, 85, 247, 0.38);
  background:
    rgba(168, 85, 247, 0.10)
    url("./assets/linguaboost-drop-purple.svg")
    center / 18px 23px no-repeat;
}

.brand-copy { display: grid; gap: 2px; min-width: 0; }

.brand-title {
  font-family: var(--display);
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.04em;
  white-space: nowrap;
}

.brand small {
  display: block;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--faint);
}

.topbar-links {
  display: flex;
  align-items: center;
  gap: 24px;
  flex: 1 1 auto;
  margin-left: 16px;
}

.top-link {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  transition: color 0.18s;
  white-space: nowrap;
}

.top-link:hover { color: var(--accent); }

.topbar-links .theme-toggle {
  margin-left: auto;
}

/* Page wrap */
.wrap {
  max-width: 1320px;
  margin: 0 auto;
  padding: 48px 28px 80px;
}

/* Hero */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid var(--line);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 56px;
  background: var(--bg-card);
}

.hero-banner { overflow: hidden; }

.hero-banner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  min-height: 380px;
}


.hero-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 44px 44px 44px 40px;
  background:
    radial-gradient(circle at 80% 20%, var(--hero-glow), transparent 44%),
    var(--bg-card);
}

/* Terminal eyebrow */
.hero-badge {
  display: block;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--plum);
  margin-bottom: 16px;
}

.hero-badge::before {
  content: "$ ";
  color: var(--accent);
}

h1 {
  font-family: var(--display);
  font-size: clamp(2.2rem, 4.2vw, 3.8rem);
  font-weight: 800;
  line-height: 0.94;
  letter-spacing: -0.06em;
  margin-bottom: 18px;
  text-shadow: 0 14px 72px var(--title-glow);
}

.lead {
  color: var(--muted);
  font-size: 15px;
  line-height: 1.76;
  margin: 0 0 28px;
  max-width: 540px;
}

.hero-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

.hero-link {
  display: inline-flex;
  align-items: center;
  min-height: 44px;
  padding: 11px 20px;
  border-radius: 10px;
  font-family: var(--body-font);
  font-size: 13px;
  font-weight: 800;
  border: 1px solid transparent;
  transition: all 0.18s;
}

.hero-link.primary {
  background: var(--accent);
  color: var(--accent-on);
}

.hero-link.primary:hover {
  background: var(--accent-hover);
}

.hero-link.secondary {
  background: transparent;
  border-color: var(--line-2);
  color: var(--muted);
}

.hero-link.secondary:hover {
  border-color: var(--plum);
  color: var(--plum-2);
}

.quick-links {
  display: flex;
  gap: 7px;
  flex-wrap: wrap;
}

.quick-link {
  display: inline-flex;
  align-items: center;
  padding: 6px 10px;
  border: 1px dotted var(--line-dot);
  border-radius: 6px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--plum);
  transition: all 0.16s;
}

.quick-link:hover {
  border-color: var(--plum);
  color: var(--plum-2);
  background: var(--quick-hover);
}

/* Level sections */
.level-grid {
  display: grid;
  gap: 24px;
  counter-reset: lab-level -1;
}

.level-section {
  position: relative;
  overflow: hidden;
  padding: 36px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--bg-card);
  counter-increment: lab-level;
}

/* Ghost section counter */
.level-section::before {
  content: counter(lab-level, decimal-leading-zero);
  position: absolute;
  top: 16px;
  right: 24px;
  font-family: var(--display);
  font-size: clamp(80px,12vw,152px);
  font-weight: 900;
  line-height: 0.8;
  letter-spacing: -0.08em;
  color: transparent;
  -webkit-text-stroke: 1.5px var(--ghost-stroke);
  pointer-events: none;
}

/* Ghost level label */
.level-section::after {
  position: absolute;
  right: 24px;
  bottom: -0.06em;
  font-family: var(--display);
  font-size: clamp(60px,10vw,132px);
  font-weight: 900;
  line-height: 0.82;
  letter-spacing: -0.07em;
  color: var(--ghost-fill);
  pointer-events: none;
}

#pre-a1::after  { content: "PRE-A1"; }
#a1::after      { content: "A1"; }
#a2::after      { content: "A2"; }
#b1::after      { content: "B1"; }
#b2-plus::after { content: "B2+"; }

.section-head {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 10px;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px dashed var(--line-dot);
}

.section-kicker {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--plum);
}

.section-kicker::before {
  content: counter(lab-level, decimal-leading-zero) " / ";
  color: var(--accent);
}

.section-head h2 {
  font-family: var(--display);
  font-size: clamp(1.8rem,3.4vw,2.9rem);
  font-weight: 800;
  line-height: 0.96;
  letter-spacing: -0.07em;
  max-width: 16ch;
}

.section-copy {
  color: var(--muted);
  font-size: 15px;
  line-height: 1.72;
  max-width: 860px;
}

.level-count {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent);
}

/* Module cards */
.module-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
  gap: 14px;
}

.module-card {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 22px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--module-bg);
  transition: border-color 0.18s;
}

.module-card:hover { border-color: var(--line-2); }

.module-meta {
  display: flex;
  gap: 7px;
  flex-wrap: wrap;
}

.module-pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 8px;
  border: 1px dotted var(--line-dot);
  border-radius: 5px;
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--plum);
}

.module-title {
  font-size: 1.16rem;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.03em;
}

.module-copy {
  flex: 1;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.68;
}

.module-link {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  margin-top: auto;
  min-height: 40px;
  padding: 10px 16px;
  border: 1px solid var(--accent-border);
  border-radius: 8px;
  background: var(--accent-soft);
  font-size: 13px;
  font-weight: 800;
  color: var(--accent);
  transition: all 0.16s;
}

.module-link:hover {
  background: var(--accent-soft-2);
  border-color: var(--accent);
  color: var(--accent-hover-text);
}

/* Terminal blocks (green counters inside text) */
.term {
  border: 1px solid var(--line-2);
  border-radius: 8px;
  padding: 12px 16px;
  font-family: var(--mono);
  font-size: 11px;
  line-height: 1.7;
  background: rgba(0,0,0,0.25);
  margin: 18px 0;
}
.term .p { color: var(--accent); }
.term div:nth-child(2),
.term .ok {
  color: var(--success);
  opacity: 0.9;
}
[data-theme="light"] .term {
  background: rgba(97,65,159,0.06);
}

.theme-toggle {
  display: inline-grid;
  place-items: center;
  width: 32px;
  height: 32px;
  flex: 0 0 32px;
  border: 1px solid var(--line-2);
  border-radius: 8px;
  background: var(--bg-card);
  color: var(--accent);
  cursor: pointer;
  font: 800 15px/1 var(--body-font);
  transition: background 0.16s, border-color 0.16s, color 0.16s;
}

.theme-toggle:hover {
  background: var(--accent-soft);
  border-color: var(--accent);
}

.lb-catalog-lang {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  flex: 0 0 auto;
}

.lbs-lang-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 32px;
  padding: 0 10px;
  border: 1px solid var(--line-2);
  border-radius: 8px;
  background: var(--bg-card);
  color: var(--muted);
  font: 800 11px/1 var(--mono);
  letter-spacing: 0.08em;
  cursor: pointer;
  transition: background 0.16s, border-color 0.16s, color 0.16s;
}

.lbs-lang-btn:hover,
.lbs-lang-btn.is-active {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--accent-on);
}

/* Footer note */
.footer-note {
  margin-top: 24px;
  padding: 20px 24px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--bg-card);
}

.footer-note p {
  margin: 0;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--faint);
  line-height: 1.8;
  text-align: center;
}

/* Responsive */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; }
  .hero-banner img { min-height: 260px; max-height: 320px; }
  .hero-copy { padding: 28px 24px 32px; }
}

@media (max-width: 640px) {
  .topbar { padding: 0 16px; }
  .brand-logo { height: 32px; max-width: 148px; }
  .brand small { display: none; }
  .topbar-links { gap: 12px; }
  .lb-catalog-lang { width: 100%; justify-content: flex-end; }
  .wrap { padding: 28px 16px 56px; }
  .level-section { padding: 24px 18px; }
  .hero-link { width: 100%; justify-content: center; }
  .hero-actions { flex-direction: column; }
}

/* Final version 4: long banner first, catalog below */
.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  height: auto;
  min-height: 52px;
  padding: 8px clamp(18px, 3vw, 28px);
  background: var(--topbar-bg);
}

.brand-mark {
  width: 30px;
  height: 30px;
  flex-basis: 30px;
  border-radius: 7px;
  background-size: 16px 21px;
}

.brand-title {
  font-size: 14px;
}

.brand small {
  display: none;
}

.topbar-links {
  gap: clamp(18px, 2.2vw, 28px);
  flex-wrap: wrap;
  justify-content: flex-start;
}

.top-link {
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.22em;
  color: var(--faint);
}

.top-link:hover {
  color: var(--text);
}

.topbar .top-link {
  padding: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  font-family: var(--mono) !important;
  font-size: 10px !important;
  font-weight: 400 !important;
  letter-spacing: 0.22em !important;
  text-transform: uppercase !important;
  color: var(--faint) !important;
  opacity: 0.9 !important;
}

.topbar .top-link:hover {
  background: transparent !important;
  color: var(--text) !important;
  opacity: 1 !important;
}

.theme-toggle {
  width: 34px;
  height: 34px;
  flex-basis: 34px;
  border-radius: 8px;
  font: 500 14px/1 var(--body-font);
}

.lbs-lang-btn {
  min-width: 38px;
  height: 34px;
  font-weight: 500;
}

.wrap {
  padding-top: 34px;
}

.hero {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
  margin-top: calc(-64px - 34px);
  padding-top: calc(120px + 34px);
  padding-left: 0;
  padding-right: 0;
  border: none !important;
  box-shadow: none !important;
  background: none;
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 40px;

  -webkit-mask-image: linear-gradient(
    to right,
    transparent 0%,
    black 8%,
    black 92%,
    transparent 100%
  );
  mask-image: linear-gradient(
    to right,
    transparent 0%,
    black 8%,
    black 92%,
    transparent 100%
  );
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-size: 100% 100%;
  mask-size: 100% 100%;
}

.hero::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: clamp(62px, 7.45vh, 80px);
  border-top: 1px dashed var(--line-dot);
  opacity: 0.55;
  pointer-events: none;
}

.hero-inner,
.hero-grid {
  border: none !important;
  box-shadow: none !important;
  background: none !important;
}

.hero-banner {
  position: absolute;
  inset: 0;
  pointer-events: none;
  user-select: none;
}

.hero-bg {
  display: block;
  position: absolute;
  right: 0;
  top: 56%;
  transform: translateY(-50%) scale(0.92);
  width: 48%;
  max-width: 820px;
  aspect-ratio: auto;
  min-height: 0;
  max-height: none;
  height: auto;
  object-fit: contain;
  object-position: right center;
  border-radius: 0 !important;

  -webkit-mask-image: linear-gradient(to left, black 30%, transparent 100%);
  mask-image: linear-gradient(to left, black 30%, transparent 100%);
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-size: 100% 100%;
  mask-size: 100% 100%;
}

.img-light { display: none; }
body.light .img-dark { display: none; }
body.light .img-light { display: block; }

.hero-copy {
  position: relative;
  z-index: 2;
  grid-column: 1 / -1;
  max-width: 1240px;
  margin: 0 auto;
  padding: 30px 32px 34px;
  transform: translateX(-38px);
  border: none !important;
  box-shadow: none !important;
  background: none;
}

.hero-copy h1 {
  max-width: min(900px, calc(100vw - 560px));
}

.hero-copy .lead {
  max-width: min(760px, calc(100vw - 560px));
}

.level-row {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.level {
  padding: 8px 14px;
  border-radius: 10px;
  border: 1px solid var(--line);
  font-size: 12px;
  font-family: var(--mono);
  color: var(--muted);
  background: transparent;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.level.active {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-soft);
}

.accent-purple {
  color: var(--plum-2);

.hero {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
  margin-top: calc(-64px - 34px);
  padding-top: calc(120px + 34px);
  padding-left: 0;
  padding-right: 0;
  border: none !important;
  box-shadow: none !important;
  background: none;
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 40px;

  -webkit-mask-image: linear-gradient(
    to right,
    transparent 0%,
    black 8%,
    black 92%,
    transparent 100%
  );

<script>
(function () {
  var storageKey = "nge-theme-lab-sky";
  var themes = ["dark", "light", "sky"];

  function syncButton(theme) {
    var button = document.getElementById("labThemeToggle");
    if (!button) return;
    var label = theme === "sky" ? "SKY" : (theme === "light" ? "LITE" : "DARK");
    button.textContent = label;
    button.setAttribute("aria-pressed", String(theme !== "light"));
    button.setAttribute("aria-label", "Theme: " + label);
    button.title = "Theme: " + label;
  }

  function applyLabTheme(theme) {
    var nextTheme = themes.indexOf(theme) >= 0 ? theme : "sky";
    document.documentElement.dataset.theme = nextTheme;
    document.body.classList.toggle("light", nextTheme === "light");
    document.body.classList.toggle("sky", nextTheme === "sky");
    localStorage.setItem(storageKey, nextTheme);
    syncButton(nextTheme);
  }

  document.addEventListener("DOMContentLoaded", function () {
    var params = new URLSearchParams(window.location.search);
    var requestedTheme = params.get("theme");
    var storedTheme = localStorage.getItem(storageKey);
    applyLabTheme(themes.indexOf(requestedTheme) >= 0 ? requestedTheme : (themes.indexOf(storedTheme) >= 0 ? storedTheme : "sky"));

    var button = document.getElementById("labThemeToggle");
    if (!button) return;
    button.addEventListener("click", function () {
      var current = document.documentElement.dataset.theme || "dark";
      var currentIndex = themes.indexOf(current);
      applyLabTheme(themes[(currentIndex + 1) % themes.length]);
    });

    function readLabProgress() {
      try {
        return JSON.parse(localStorage.getItem("linguaboost.lab.progress.v1") || "{}");
      } catch (error) {
        return {};
      }
    }

    function renderModuleProgress() {
      var progress = readLabProgress();
      var total = 8;
      var moduleProgress = progress.a1 || { lessons: {} };
      var lessons = moduleProgress.lessons || {};
      var completed = Object.keys(lessons).filter(function (id) {
        return lessons[id] && lessons[id].completed;
      }).length;
      var percent = Math.min(100, Math.round((completed / total) * 100));
      var card = document.querySelector('[data-module-progress="a1"]');
      var text = document.querySelector("[data-module-progress-text]");
      var fill = document.querySelector("[data-module-progress-fill]");
      if (text) text.textContent = completed + " / " + total;
      if (fill) fill.style.width = percent + "%";
      if (card) card.classList.toggle("is-complete", completed >= total);
      document.querySelectorAll("[data-lab-lesson]").forEach(function (lessonCard) {
        var id = lessonCard.getAttribute("data-lab-lesson");
        lessonCard.classList.toggle("is-complete", Boolean(lessons[id] && lessons[id].completed));
      });
    }

    renderModuleProgress();
    window.addEventListener("storage", renderModuleProgress);
    window.addEventListener("linguaboost:progress", renderModuleProgress);
  });
})();
</script>
<script defer src="./assets/studio-module-shell.js"></script>
</body>

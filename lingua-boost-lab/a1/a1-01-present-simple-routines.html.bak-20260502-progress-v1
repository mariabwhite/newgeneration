        { src: "../assets/a1-story-kids-light-01-get-up.png", alt: "Alex gets up in the morning", label: "7:00 · get up" },
        { src: "../assets/a1-story-kids-light-02-breakfast.png", alt: "Alex has breakfast", label: "7:30 · breakfast" },
        { src: "../assets/a1-story-kids-light-03-school.png", alt: "Alex goes to school", label: "8:00 · class" },
        { src: "../assets/a1-story-kids-light-04-plan.png", alt: "Alex plans the day", label: "22:00 · plan" }
      ],
      dark: [
        { src: "../assets/a1-story-kids-dark-01-get-up.png", alt: "Alex gets up in a dark room", label: "7:00 · get up" },
        { src: "../assets/a1-story-kids-dark-02-breakfast.png", alt: "Alex has breakfast in the evening-style dark scene", label: "7:30 · breakfast" },
        { src: "../assets/a1-story-kids-dark-03-school.png", alt: "Alex goes to school in a dark scene", label: "8:00 · class" },
        { src: "../assets/a1-story-kids-dark-04-bed.png", alt: "Alex reads in bed in a dark room", label: "22:00 · bed" }
      ]
    },
    adults: {
      light: [
        { src: "../assets/a1-story-adults-light-01-work.png", alt: "Adult works on a laptop in a bright room", label: "9:00 · work" },
        { src: "../assets/a1-story-adults-light-02-lunch.png", alt: "Adult lunch bowl in a bright room", label: "13:00 · lunch" },
        { src: "../assets/a1-story-adults-light-03-bed.png", alt: "Adult bedroom in a bright room", label: "22:00 · bed" },
        { src: "../assets/a1-story-adults-light-04-clock.png", alt: "Clock for planning a routine in a bright room", label: "7:00 · plan" }
      ],
      dark: [
        { src: "../assets/a1-story-adults-dark-01-work.png", alt: "Adult works on a laptop in a dark room", label: "9:00 · work" },
        { src: "../assets/a1-story-adults-dark-02-lunch.png", alt: "Adult lunch bowl in a dark room", label: "13:00 · lunch" },
        { src: "../assets/a1-story-adults-dark-03-bed.png", alt: "Adult bedroom in a dark room", label: "22:00 · bed" },
        { src: "../assets/a1-story-adults-dark-04-clock.png", alt: "Clock for planning a routine in a dark room", label: "7:00 · plan" }
      ]
    }
  };

  function getVisualMode() {
    const theme = root.getAttribute("data-theme") || "light-lab";
    return darkHeroThemes.has(theme) ? "dark" : "light";
  }

  function updateHeroImage() {
    if (!heroImg) return;
    const audience = document.body.dataset.audience === "adults" ? "adults" : "kids";
    const mode = getVisualMode();
    const asset = heroAssets[audience][mode];
    heroImg.src = asset.src;
    heroImg.alt = asset.alt;
  }

  function updateStoryImages() {
    if (!storyImgs.length) return;
    const audience = document.body.dataset.audience === "adults" ? "adults" : "kids";
    const mode = getVisualMode();
    storyAssets[audience][mode].forEach((asset, index) => {
      const img = storyImgs[index];
      const label = storyLabels[index];
      if (img) {
        img.src = asset.src;
        img.alt = asset.alt;
      }
      if (label) label.textContent = asset.label;
    });
  }

  function applyPalette(palette) {
    const safe = palettes.includes(palette) ? palette : "light-lab";
    root.setAttribute("data-theme", safe);
    if (paletteSelect) paletteSelect.value = safe;
    localStorage.setItem(paletteKey, safe);
    updateHeroImage();
    updateStoryImages();
  }

  function applyLang(lang) {
    const safe = lang === "en" ? "en" : "ru";
    root.setAttribute("lang", safe);
    document.querySelectorAll("[data-ru][data-en]").forEach(node => {
      if (node.closest(".vocab-card")) return;
      node.innerHTML = node.dataset[safe];
    });
    langButtons.forEach(btn => btn.classList.toggle("is-active", btn.dataset.langBtn === safe));
    localStorage.setItem(langKey, safe);
  }

  document.body.dataset.audience = localStorage.getItem("lesson-audience") || "kids";
  applyPalette(localStorage.getItem(paletteKey) || root.getAttribute("data-theme") || "light-lab");
  applyLang(localStorage.getItem(langKey) || "en");

  paletteSelect?.addEventListener("change", event => applyPalette(event.target.value));
  document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
    const current = root.getAttribute("data-theme") || "light-lab";
    applyPalette(current === "black-lab" ? "light-lab" : "black-lab");
  });
  langButtons.forEach(btn => btn.addEventListener("click", () => applyLang(btn.dataset.langBtn)));

  function applyAudience(audience) {
    const safe = audience === "adults" ? "adults" : "kids";
    document.body.dataset.audience = safe;
    document.querySelectorAll("[data-audience-btn]").forEach(btn => btn.classList.toggle("is-active", btn.dataset.audienceBtn === safe));
    document.querySelectorAll("[data-kids][data-adults]").forEach(node => {
      node.textContent = node.dataset[safe];
    });
    localStorage.setItem("lesson-audience", safe);
    updateHeroImage();
    updateStoryImages();
  }
  applyAudience(document.body.dataset.audience || "kids");
  document.querySelectorAll("[data-audience-btn]").forEach(btn => btn.addEventListener("click", () => applyAudience(btn.dataset.audienceBtn)));

  document.querySelectorAll(".practice-hint").forEach(btn => {
    btn.addEventListener("click", () => {
      const answer = btn.dataset.answer || "";
      btn.textContent = answer;
      btn.classList.add("shown");
    });
  });

  document.querySelectorAll(".choice").forEach(btn => {
    btn.addEventListener("click", () => {
      const row = btn.closest(".choice-row");
      row?.querySelectorAll(".choice").forEach(item => {
        item.classList.remove("is-picked");
        item.removeAttribute("data-state");
      });
      btn.classList.add("is-picked");
      btn.dataset.state = btn.dataset.correct === "true" ? "correct" : "wrong";
    });
  });

  document.querySelectorAll(".vocab-card").forEach(card => {
    card.addEventListener("click", event => {
      if (event.target.closest(".speak-btn")) return;
      card.classList.toggle("is-flipped");
    });
    card.addEventListener("keydown", event => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        card.classList.toggle("is-flipped");
      }
    });
  });

  document.querySelectorAll(".speak-btn").forEach(btn => {
    btn.addEventListener("click", event => {
      event.stopPropagation();
      if (!("speechSynthesis" in window)) return;
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(btn.dataset.say || btn.textContent || "");
      utterance.lang = "en-US";
      utterance.rate = 0.86;
      window.speechSynthesis.speak(utterance);
    });
  });

  const stepBlocks = [
    ["goal", "Goal"],
    ["input", "Words"],
    ["focus", "Grammar"],
    ["guided", "Practice"],
    ["active", "Build"],
    ["text", "Alex"],
    ["output", "Speak / write"],
    ["final-task", "Final"]
  ];
  const currentEl = document.querySelector("[data-step-current]");
  const fillEl = document.querySelector("[data-step-fill]");
  const nameEl = document.querySelector("[data-step-name]");
  function updateStep() {
    let activeIndex = 0;
    stepBlocks.forEach(([id], index) => {
      const block = document.getElementById(id);
      if (block && block.getBoundingClientRect().top < window.innerHeight * 0.42) activeIndex = index;
    });
    if (currentEl) currentEl.textContent = String(activeIndex + 1).padStart(2, "0");
    if (fillEl) fillEl.style.width = `${((activeIndex + 1) / stepBlocks.length) * 100}%`;
    if (nameEl) nameEl.textContent = stepBlocks[activeIndex][1];
  }
  updateStep();
  window.addEventListener("scroll", updateStep, { passive: true });

  let flipIndex = 0;
  document.querySelector("[data-flip-next]")?.addEventListener("click", () => {
    const cards = [...document.querySelectorAll(".vocab-card")];
    if (!cards.length) return;
    cards.forEach((card, index) => card.classList.toggle("is-flipped", index === flipIndex));
    cards[flipIndex].scrollIntoView({ behavior: "smooth", block: "center" });
    flipIndex = (flipIndex + 1) % cards.length;
  });

  let selectedWord = "";
  document.querySelectorAll(".word-chip").forEach(chip => {
    chip.addEventListener("click", () => {
      document.querySelectorAll(".word-chip").forEach(item => item.classList.remove("is-selected"));
      chip.classList.add("is-selected");
      selectedWord = chip.textContent.trim();
    });
    chip.addEventListener("dragstart", event => {
      selectedWord = chip.textContent.trim();
      event.dataTransfer?.setData("text/plain", selectedWord);
    });
  });
  document.querySelectorAll("[data-drop]").forEach(slot => {
    function fillSlot(value) {
      if (!value) return;
      slot.textContent = value;
      slot.classList.add("filled");
    }
    slot.addEventListener("click", () => fillSlot(selectedWord));
    slot.addEventListener("dragover", event => event.preventDefault());
    slot.addEventListener("drop", event => {
      event.preventDefault();
      fillSlot(event.dataTransfer?.getData("text/plain") || selectedWord);
    });
  });

  let mediaRecorder;
  let audioChunks = [];
  const startBtn = document.querySelector("[data-record-start]");
  const stopBtn = document.querySelector("[data-record-stop]");
  const audioEl = document.querySelector("[data-record-audio]");
  const recordDot = document.querySelector("[data-record-dot]");
  startBtn?.addEventListener("click", async () => {
    if (!navigator.mediaDevices?.getUserMedia) return;
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    audioChunks = [];
    mediaRecorder = new MediaRecorder(stream);
    mediaRecorder.addEventListener("dataavailable", event => {
      if (event.data.size > 0) audioChunks.push(event.data);
    });
    mediaRecorder.addEventListener("stop", () => {
      const blob = new Blob(audioChunks, { type: "audio/webm" });
      if (audioEl) audioEl.src = URL.createObjectURL(blob);
      stream.getTracks().forEach(track => track.stop());
    });
    mediaRecorder.start();
    startBtn.setAttribute("disabled", "true");
    stopBtn?.removeAttribute("disabled");
    recordDot?.classList.add("is-recording");
  });
  stopBtn?.addEventListener("click", () => {
    mediaRecorder?.stop();
    stopBtn.setAttribute("disabled", "true");
    startBtn?.removeAttribute("disabled");
    recordDot?.classList.remove("is-recording");
  });
})();
</script>
</body>
</html>


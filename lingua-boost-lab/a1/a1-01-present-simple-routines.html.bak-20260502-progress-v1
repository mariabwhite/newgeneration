:root {
  --display: "Unbounded", "Manrope", system-ui, sans-serif;
  --body: "Manrope", system-ui, sans-serif;
  --mono: "JetBrains Mono", Consolas, monospace;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0; min-height: 100vh; font-family: var(--body); color: var(--text);
  background:
    radial-gradient(circle at 82% 4%, var(--hero-glow1), transparent 38%),
    radial-gradient(circle at 8% 38%, var(--hero-glow2), transparent 32%),
    var(--bg);
  background-attachment: fixed;
  transition: background 0.3s, color 0.3s;
}
a { color: inherit; text-decoration: none; }
h1, h2, h3, h4, p { margin: 0; }
button, input, select, textarea { font: inherit; }
.topbar {
  position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; gap: 16px;
  padding: 10px clamp(16px, 3vw, 28px);
  background: color-mix(in srgb, var(--bg) 88%, transparent);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  min-height: 56px;
}
.brand { display: flex; align-items: center; gap: 12px; }
.brand-mark {
  width: 36px; height: 36px; border: 1px solid var(--line-2); border-radius: 8px;
  display: grid; place-items: center; background: var(--soft); position: relative;
}
.brand-mark::before {
  content: "L"; font-family: var(--display); font-size: 20px; font-weight: 900;
  color: var(--accent); line-height: 1; letter-spacing: -0.04em;
}
.brand-mark::after {
  content: ""; position: absolute; right: 4px; bottom: 4px; width: 5px; height: 5px;
  border-radius: 50%; background: var(--brand);
}
.brand-copy { display: grid; gap: 2px; }
.brand-name { font-family: var(--display); font-size: 14px; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
.brand-tag { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); }
.topbar-nav { display: flex; gap: clamp(12px, 2vw, 22px); margin-left: 12px; flex-wrap: wrap; }
.top-link {
  font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--muted); transition: color 0.18s;
}
.top-link:hover, .top-link.active { color: var(--accent); }
.topbar-tools { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.btn-tool {
  height: 32px; min-width: 38px; padding: 0 10px; border: 1px solid var(--line-2);
  border-radius: 8px; background: var(--card); color: var(--muted);
  font: 800 11px/1 var(--mono); letter-spacing: 0.08em; cursor: pointer;
  display: inline-grid; place-items: center; transition: all 0.16s;
}
select.btn-tool { width: 118px; }
.btn-tool:hover { border-color: var(--accent); color: var(--accent); }
.btn-tool.is-active { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
.wrap { max-width: 1240px; margin: 0 auto; padding: 32px clamp(16px, 3vw, 28px) 80px; }
.crumbs {
  display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 22px;
  font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--faint);
}
.crumbs a { color: var(--muted); transition: color 0.18s; }
.crumbs a:hover { color: var(--accent); }
.crumbs .sep { color: var(--line-dot); }
.crumbs .here { color: var(--brand); }
.hero {
  position: relative; border: 1px solid var(--line); border-radius: 18px;
  padding: clamp(26px, 5vw, 56px); margin-bottom: 18px;
  background:
    radial-gradient(circle at 88% 14%, var(--hero-glow1), transparent 42%),
    radial-gradient(circle at 8% 88%, var(--hero-glow2), transparent 50%),
    var(--card);
  overflow: hidden;
}
.hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.28fr 0.92fr; gap: 40px; align-items: center; }
.hero-eyebrow {
  font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--brand); margin-bottom: 16px;
}
.hero-eyebrow::before { content: "$ "; color: var(--accent); }
.hero-title {
  font-family: var(--display); font-size: clamp(2.05rem, 5vw, 4.25rem); line-height: 0.96;
  letter-spacing: -0.05em; margin-bottom: 18px;
}
.hero-title em { font-style: normal; color: var(--accent); }
.hero-lead { color: var(--muted); font-size: clamp(15px, 1.4vw, 17px); line-height: 1.7; max-width: 760px; margin-bottom: 20px; }
.hero-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.pill {
  display: inline-grid; place-items: center; min-height: 28px; padding: 6px 10px;
  border: 1px solid var(--line-2); border-radius: 999px; background: var(--soft);
  color: var(--muted); font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
}
.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.btn {
  display: inline-grid; place-items: center; min-height: 42px; padding: 0 18px; border-radius: 8px;
  border: 1px solid var(--line-2); font-family: var(--mono); font-size: 11px; font-weight: 800;
  letter-spacing: 0.12em; text-transform: uppercase; transition: transform 0.16s, border-color 0.16s, background 0.16s;
}
.btn:hover { transform: translateY(-1px); border-color: var(--accent); }
.btn.primary { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
.btn.ghost { background: var(--soft); color: var(--text); }
.hero-photo {
  position: relative; min-height: 320px; border-radius: 16px; border: 1px solid var(--line-2);
  overflow: hidden; background: var(--card-2);
  box-shadow: 0 30px 80px -28px var(--hero-glow1);
}
.hero-img {
  width: 100%; height: 100%; min-height: inherit; object-fit: cover; display: block;
}
.flip-grid { perspective: 1200px; }
.vocab-card {
  min-height: 196px; padding: 0; background: transparent; border: none; transform-style: preserve-3d;
}
.vocab-card:hover { transform: none; }
.vocab-card.is-flipped .vocab-inner { transform: rotateY(180deg); }
.vocab-inner {
  position: relative; min-height: 196px; transition: transform 0.45s ease; transform-style: preserve-3d;
}
.vocab-face {
  position: absolute; inset: 0; display: grid; align-content: space-between; gap: 12px;
  padding: 16px 18px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
  backface-visibility: hidden;
}
.vocab-back { transform: rotateY(180deg); }
.vocab-actions { display: flex; gap: 8px; flex-wrap: wrap; }
.icon-btn {
  width: 34px; height: 34px; display: inline-grid; place-items: center; border: 1px solid var(--line-2);
  border-radius: 8px; background: var(--soft); color: var(--text); cursor: pointer;
  font-family: var(--mono); font-weight: 900;
}
.icon-btn:hover { border-color: var(--accent); color: var(--accent); }
.flip-note { font-family: var(--mono); font-size: 10px; color: var(--faint); letter-spacing: 0.12em; text-transform: uppercase; }
.grammar-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 12px; margin-bottom: 14px; }
.grammar-table { width: 100%; min-width: 760px; border-collapse: collapse; background: var(--card-2); }
.grammar-table th, .grammar-table td { padding: 14px 16px; border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); vertical-align: top; text-align: left; }
.grammar-table th:last-child, .grammar-table td:last-child { border-right: none; }
.grammar-table tr:last-child td { border-bottom: none; }
.grammar-table th { font-family: var(--display); font-size: 15px; letter-spacing: -0.02em; color: var(--text); }
.grammar-table .formula { color: var(--accent); font-family: var(--mono); font-size: 12px; line-height: 1.5; }
.grammar-table .sample { color: var(--muted); line-height: 1.55; }
.choice[data-state="correct"] { border-color: var(--ok); color: var(--ok); }
.choice[data-state="wrong"] { border-color: var(--warn); color: var(--warn); }
.scene-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 14px; }
.scene-card {
  min-height: 188px; border: 1px solid var(--line); border-radius: 14px; background: var(--card-2);
  display: grid; align-content: end; position: relative; overflow: hidden;
  box-shadow: 0 18px 34px rgba(8,19,50,0.08);
}
.scene-card img {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.22s ease, filter 0.22s ease;
}
.scene-card:hover img { transform: scale(1.03); }
.scene-card::after {
  content: ""; position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 46%, rgba(0,0,0,0.58) 100%);
}
.scene-card span {
  position: relative; z-index: 1; margin: 12px; width: fit-content;
  border-radius: 999px; padding: 7px 10px; background: rgba(255,255,255,0.9);
  font-family: var(--mono); font-size: 10px; color: #081332; text-transform: uppercase; letter-spacing: 0.1em;
}
.prompt-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin-bottom: 14px; }
.prompt-card {
  border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; background: var(--card-2);
  display: grid; gap: 8px;
}
.prompt-card label { display: flex; gap: 10px; align-items: flex-start; line-height: 1.45; color: var(--text); }
.prompt-card input[type="checkbox"] { margin-top: 3px; accent-color: var(--accent); }
.now-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
.now-item {
  border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; background: var(--card-2);
}
.now-item label { display: flex; gap: 10px; align-items: flex-start; color: var(--muted); line-height: 1.45; }
.now-item input { margin-top: 3px; accent-color: var(--ok); }
.step-tracker {
  position: sticky; top: 56px; z-index: 20; display: grid; grid-template-columns: auto 1fr auto; gap: 14px;
  align-items: center; padding: 12px 14px; margin: 0 0 18px; border: 1px solid var(--line);
  border-radius: 12px; background: color-mix(in srgb, var(--card) 92%, transparent); backdrop-filter: blur(14px);
}
.step-count { font-family: var(--mono); font-size: 10px; font-weight: 800; color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase; }
.step-track { height: 8px; border-radius: 999px; background: var(--soft); overflow: hidden; }
.step-fill { height: 100%; width: 12.5%; background: var(--accent); border-radius: inherit; transition: width 0.2s; }
.step-name { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; }
.block-nav { display: flex; justify-content: flex-end; gap: 10px; margin-top: 18px; }
.bank.interactive { gap: 10px; margin-bottom: 18px; }
.word-chip {
  display: inline-grid; place-items: center; min-height: 32px; padding: 7px 11px; border-radius: 999px;
  border: 1px solid var(--line-2); background: var(--card-2); color: var(--text);
  font-family: var(--mono); font-size: 11px; font-weight: 800; cursor: grab;
}
.word-chip.is-selected { border-color: var(--accent); color: var(--accent); }
.drop-slot {
  display: inline-grid; place-items: center; min-width: 128px; min-height: 30px; padding: 3px 10px;
  border: 1px dashed var(--accent); border-radius: 999px; color: var(--faint);
}
.drop-slot.filled { border-style: solid; color: var(--text); background: var(--soft); }
.recorder {
  display: grid; gap: 12px; padding: 16px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
  margin-top: 14px;
}
.recorder-controls { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
.record-dot {
  width: 10px; height: 10px; border-radius: 50%; background: var(--faint); display: inline-block;
}
.record-dot.is-recording { background: #ff4d5f; box-shadow: 0 0 0 6px rgba(255,77,95,0.16); }
.block {
  position: relative; border: 1px solid var(--line); border-radius: 16px; padding: clamp(20px, 3vw, 30px);
  margin: 18px 0; background: color-mix(in srgb, var(--card) 92%, transparent);
}
.block-head { display: flex; gap: 14px; align-items: flex-start; padding-bottom: 18px; border-bottom: 1px solid var(--line); margin-bottom: 18px; }
.block-num {
  flex: 0 0 auto; width: 44px; height: 44px; border-radius: 10px; border: 1px solid var(--line-2);
  display: grid; place-items: center; background: var(--soft); color: var(--accent);
  font-family: var(--mono); font-size: 13px; font-weight: 800;
}
.block-title-wrap { flex: 1; min-width: 0; }
.block-kicker {
  font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--brand); margin-bottom: 5px;
}
.block-title { font-family: var(--display); font-size: clamp(1.35rem, 2.4vw, 2rem); line-height: 1.05; letter-spacing: -0.04em; }
.block-time {
  flex: 0 0 auto; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 8px 10px;
}
.block-intro { color: var(--muted); font-size: 15px; line-height: 1.66; margin-bottom: 18px; max-width: 860px; }
.goal-grid, .focus-grid, .output-grid, .check-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.info-card, .example, .error-card, .text-card {
  border: 1px solid var(--line); border-radius: 12px; padding: 16px 18px; background: var(--card-2);
}
.info-card h3, .text-card h3, .error-card h3 {
  font-family: var(--display); font-size: 15px; letter-spacing: -0.02em; margin-bottom: 8px;
}
.info-card p, .text-card p, .error-card p { color: var(--muted); line-height: 1.6; font-size: 14px; }
.info-card ul, .text-card ul, .error-card ul { margin: 8px 0 0 18px; padding: 0; color: var(--muted); line-height: 1.65; }
.vocab-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 12px; }
.vocab-card {
  padding: 16px 18px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
  transition: transform 0.16s, border-color 0.16s;
}
.vocab-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.vocab-en { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
.vocab-word { font-family: var(--display); font-size: 18px; font-weight: 800; letter-spacing: -0.02em; }
.vocab-ipa { font-family: var(--mono); font-size: 11px; color: var(--faint); }
.vocab-ru { color: var(--muted); font-size: 14px; line-height: 1.5; }
.vocab-example { margin-top: 10px; color: var(--text); font-size: 13px; line-height: 1.5; }
.grammar-rule {
  border-left: 3px solid var(--accent); padding: 14px 18px; background: var(--term-bg);
  border-radius: 0 12px 12px 0; color: var(--muted); line-height: 1.65; margin-bottom: 14px;
}
.grammar-rule strong { color: var(--accent); font-weight: 800; }
.example-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 12px; margin-bottom: 14px; }
.example-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); margin-bottom: 6px; }
.example-text { color: var(--text); line-height: 1.55; }
.error-card { border-color: color-mix(in srgb, var(--warn) 45%, var(--line)); }
.bad { color: var(--warn); }
.good { color: var(--ok); }
.practice-list { display: grid; gap: 12px; margin: 0; padding: 0; list-style: none; }
.practice-item {
  display: grid; grid-template-columns: 34px 1fr auto; gap: 14px; align-items: center;
  padding: 14px 16px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
}
.practice-num { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--accent); }
.practice-q { font-size: 15px; line-height: 1.5; }
.blank {
  display: inline-block; min-width: 105px; padding: 2px 8px; border: none; border-bottom: 2px dashed var(--accent);
  background: transparent; color: var(--text); outline: none;
}
.blank:focus { border-bottom-color: var(--brand); }
.choice-row { display: flex; gap: 8px; flex-wrap: wrap; }
.choice {
  border: 1px solid var(--line-2); border-radius: 999px; padding: 7px 11px; background: var(--soft);
  color: var(--muted); cursor: pointer; font-family: var(--mono); font-size: 11px; font-weight: 800;
}
.choice:hover, .choice.is-picked { border-color: var(--accent); color: var(--accent); }
.practice-hint {
  border: 1px dashed var(--line-2); background: transparent; color: var(--faint); border-radius: 999px;
  padding: 7px 10px; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; cursor: pointer;
}
.practice-hint:hover { color: var(--brand); border-color: var(--brand); }
.practice-hint.shown { color: var(--ok); border-color: var(--ok); border-style: solid; }
.bank { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
.bank span {
  display: inline-grid; place-items: center; min-height: 28px; padding: 5px 10px; border: 1px solid var(--line);
  border-radius: 999px; color: var(--muted); background: var(--soft); font-family: var(--mono); font-size: 11px;
}
.text-card { margin-bottom: 14px; }
.text-card p + p { margin-top: 10px; }
.speaking-list { display: grid; gap: 10px; margin: 0; padding: 0; list-style: none; }
.speaking-item {
  display: grid; grid-template-columns: auto 1fr; gap: 14px; padding: 14px 18px;
  border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
}
.speaking-mark {
  width: 28px; height: 28px; border-radius: 50%; display: grid; place-items: center;
  background: var(--accent); color: var(--accent-on); font-family: var(--mono); font-weight: 900;
}
.speaking-q { font-size: 15px; line-height: 1.55; padding-top: 2px; }
.speaking-q .clue { display: block; margin-top: 4px; font-family: var(--mono); font-size: 11px; color: var(--faint); }
.write-box {
  width: 100%; min-height: 138px; resize: vertical; border: 1px solid var(--line-2); border-radius: 12px;
  padding: 14px 16px; background: var(--term-bg); color: var(--text); outline: none; line-height: 1.55;
}
.write-box:focus { border-color: var(--accent); }
.minitask {
  display: grid; gap: 14px; border: 1px solid var(--line-2); border-radius: 14px; padding: 18px;
  background: radial-gradient(circle at 92% 8%, var(--hero-glow1), transparent 50%), var(--card-2);
}
.minitask-title { font-family: var(--display); font-size: 18px; font-weight: 800; letter-spacing: -0.02em; }
.minitask-detail { color: var(--muted); line-height: 1.65; }
.minitask-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.lesson-foot {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 24px;
}
.foot-link {
  border: 1px solid var(--line); border-radius: 14px; padding: 18px; background: var(--card);
  display: grid; gap: 6px; transition: border-color 0.16s, transform 0.16s;
}
.foot-link:hover { border-color: var(--accent); transform: translateY(-1px); }
.foot-link.next { text-align: right; }
.foot-meta { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--brand); }
.foot-title { font-family: var(--display); font-size: 18px; font-weight: 800; letter-spacing: -0.02em; }
.copyright { margin-top: 24px; color: var(--faint); font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; }

/* Friendly Lab Shell */
body { background: #fffaf5; color: #081332; }
.friendly-topbar { min-height: 70px; padding: 10px clamp(18px, 3vw, 34px); background: rgba(255,255,255,0.92); border-bottom: 1px solid rgba(8,19,50,0.10); box-shadow: 0 10px 30px rgba(8,19,50,0.05); }
.friendly-brand { gap: 10px; }
.lab-flask { width: 38px; height: 38px; border: 0; background: rgba(255,105,10,0.10); border-radius: 12px; }
.lab-flask::before { content: "⚗"; color: #ff690a; font-family: var(--body); font-size: 26px; letter-spacing: 0; }
.lab-flask::after { display: none; }
.friendly-brand-copy { display: flex; align-items: center; gap: 8px; }
.friendly-brand .brand-name { font-family: var(--body); font-size: 24px; font-weight: 900; color: #081332; letter-spacing: -0.04em; }
.lab-tag { display: inline-grid; place-items: center; min-height: 24px; padding: 0 7px; border: 2px solid #ff690a; border-radius: 6px; color: #ff690a; font-size: 13px; letter-spacing: 0.06em; }
.friendly-nav { margin-left: clamp(20px, 5vw, 70px); gap: clamp(22px, 4vw, 54px); }
.friendly-nav .top-link { font-family: var(--body); font-size: 16px; font-weight: 750; letter-spacing: 0; text-transform: none; color: #111827; }
.friendly-nav .top-link:hover, .friendly-nav .top-link.active { color: #ff690a; }
.audience-switch { margin-left: auto; display: flex; align-items: center; gap: 4px; min-width: 218px; height: 48px; padding: 5px; border: 2px solid rgba(8,19,50,0.13); border-radius: 999px; background: #fff; }
.audience-btn { flex: 1; height: 38px; border: 0; border-radius: 999px; background: transparent; color: #111827; font: 850 16px/1 var(--body); cursor: pointer; }
.audience-btn.is-active { background: #ff690a; color: #fff; box-shadow: 0 10px 22px rgba(255,105,10,0.24); }
.friendly-tools { margin-left: 18px; }
.friendly-tools .btn-tool { height: 34px; border-radius: 999px; background: #fff; color: #111827; letter-spacing: 0; }
.level-bubble { width: 46px; height: 46px; display: grid; place-items: center; border: 1px solid rgba(8,19,50,0.13); border-radius: 50%; background: #fff; color: #081332; font-weight: 900; }
.menu-btn { width: 42px; height: 42px; border: 0; background: transparent; display: grid; gap: 5px; align-content: center; cursor: pointer; }
.menu-btn span { display: block; height: 3px; border-radius: 999px; background: #081332; }
.wrap { max-width: none; padding: 0 0 78px; }
.crumbs { display: none; }
.friendly-hero { border: 0; border-radius: 0; margin: 0; padding: 0; min-height: 480px; background: #fff; overflow: hidden; }
.friendly-hero-inner { display: grid; grid-template-columns: minmax(390px, 0.82fr) 1.18fr; gap: 0; min-height: 480px; }
.hero-copy-panel { position: relative; z-index: 2; padding: clamp(42px, 6vw, 72px) 28px clamp(42px, 5vw, 64px) clamp(28px, 4vw, 56px); background: linear-gradient(90deg, #fff 0%, rgba(255,255,255,0.96) 72%, rgba(255,255,255,0) 100%); }
.friendly-eyebrow { color: #ff690a; font-family: var(--body); font-size: 19px; font-weight: 900; letter-spacing: 0; text-transform: none; margin-bottom: 12px; }
.friendly-eyebrow::before { content: ""; }
.friendly-title { max-width: 560px; font-family: var(--body); font-size: clamp(3rem, 5.8vw, 5.3rem); line-height: 0.96; letter-spacing: -0.075em; color: #071433; }
.friendly-title em { color: #071433; }
.friendly-lead { max-width: 520px; color: #3d465d; font-size: 20px; line-height: 1.46; margin-bottom: 28px; }
.friendly-meta { display: grid; grid-template-columns: repeat(2, minmax(180px, 1fr)); gap: 16px; max-width: 470px; margin-bottom: 26px; }
.info-pill { display: grid; grid-template-columns: 46px 1fr; align-items: center; gap: 12px; min-height: 78px; padding: 12px 16px; border: 1px solid rgba(8,19,50,0.11); border-radius: 14px; background: rgba(255,255,255,0.82); box-shadow: 0 16px 34px rgba(8,19,50,0.06); color: #081332; }
.info-pill strong { font-size: 14px; }
.info-icon { width: 38px; height: 38px; display: grid; place-items: center; border: 3px solid #7790bf; border-radius: 50%; color: #36578c; font-weight: 900; }
.friendly-photo { min-height: 480px; border: 0; border-radius: 0; box-shadow: none; background: #fff3e7; }
.friendly-photo::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 32%; z-index: 1; background: linear-gradient(90deg, #fff 0%, rgba(255,255,255,0.86) 30%, rgba(255,255,255,0) 100%); }
.friendly-photo .hero-img { min-height: 480px; object-fit: cover; object-position: center; }
.btn { border-radius: 14px; font-family: var(--body); letter-spacing: 0; text-transform: none; font-size: 15px; font-weight: 850; min-height: 48px; padding: 0 20px; }
.btn.primary { background: #ff690a; border-color: #ff690a; color: #fff; box-shadow: 0 16px 26px rgba(255,105,10,0.20); }
.btn.ghost { background: #fff; color: #081332; border-color: rgba(8,19,50,0.14); }
.lesson-flow, .learn-panel { width: min(100% - 56px, 1440px); margin: -32px auto 22px; position: relative; z-index: 5; border: 1px solid rgba(8,19,50,0.10); border-radius: 22px; background: rgba(255,255,255,0.94); box-shadow: 0 24px 70px rgba(8,19,50,0.08); padding: 26px 28px; }
.lesson-flow h2, .learn-panel h2 { font-family: var(--body); font-size: 18px; letter-spacing: 0; color: #081332; margin-bottom: 16px; }
.flow-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 48px; }
.flow-card { position: relative; min-height: 132px; border: 1px solid rgba(8,19,50,0.10); border-radius: 16px; background: #fff; padding: 28px 18px 18px 86px; display: grid; align-content: center; gap: 8px; color: #081332; }
.flow-card:not(:last-child)::after { content: "→"; position: absolute; right: -34px; top: 50%; transform: translateY(-50%); color: #617291; font-size: 30px; }
.flow-num { position: absolute; left: 16px; top: 14px; width: 28px; height: 28px; display: grid; place-items: center; border-radius: 50%; background: #ff690a; color: #fff; font-weight: 900; }
.flow-icon { position: absolute; left: 28px; bottom: 24px; color: #ffb21a; font-size: 42px; line-height: 1; }
.flow-card strong { font-size: 15px; }
.flow-card small { color: #374151; line-height: 1.45; }
.learn-panel { margin-top: 0; display: grid; grid-template-columns: 1fr 390px; gap: 28px; background: linear-gradient(135deg, #fff 0%, #fff3e8 100%); }
.learn-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 22px 36px; }
.learn-grid span { position: relative; padding-left: 30px; color: #081332; line-height: 1.45; }
.learn-grid span::before { content: "✓"; position: absolute; left: 0; top: 0; color: #ff690a; font-weight: 900; }
.certificate-card { align-self: center; min-height: 96px; border: 1px solid rgba(255,105,10,0.18); border-radius: 18px; background: #fff; display: grid; grid-template-columns: 64px 1fr; gap: 14px; align-items: center; padding: 18px; }
.cert-star { grid-row: span 2; width: 58px; height: 58px; display: grid; place-items: center; border-radius: 50%; background: #ff690a; color: #fff; font-size: 32px; }
.certificate-card small { color: #374151; }
.step-tracker { width: min(100% - 56px, 1440px); margin: 0 auto 18px; top: 70px; }
.block, .lesson-foot, .copyright { width: min(100% - 56px, 1180px); margin-left: auto; margin-right: auto; }
body[data-audience="adults"] .audience-btn[data-audience-btn="kids"] { background: transparent; color: #111827; box-shadow: none; }

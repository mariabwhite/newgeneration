.task-feedback.bad { color:var(--bad); }
.input-line { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
.input-line input,.input-line select,.cert-input { min-height:38px; border:1px solid var(--line-2); border-radius:10px; padding:0 12px; background:var(--card); color:var(--text); min-width:220px; }
.match-grid { display:grid; gap:8px; max-width:560px; }
.match-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; align-items:center; }
.build-output { min-height:38px; border:1px dashed var(--line-2); border-radius:12px; padding:8px 10px; color:var(--muted); background:var(--term-bg); }

.drop-slot.filled { border-style:solid; color:var(--text); background:var(--soft); }
.drop-slot.is-correct { border-color:var(--ok); color:var(--ok); }
.mission-board { display:grid; gap:14px; }
.story-builder { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

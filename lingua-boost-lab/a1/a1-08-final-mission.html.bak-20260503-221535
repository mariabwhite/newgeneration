  transform: translateY(3px);
  box-shadow: 0 2px 0 #a6531e, 0 10px 18px rgba(166,83,30,.12);
}
.choice:hover,
.choice.is-picked,
.sentence-chip:hover,
.word-chip:hover {
  border-color: #ff9e2f;
  color: #aa6f20;
  background: #fee3a0;
}
.cert-seal {
  background: #ffd966;
  color: #aa6f20;
}




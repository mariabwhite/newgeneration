.round-tab.is-done { border-color:color-mix(in srgb,var(--ok) 70%,var(--line)); }
.round-panel { border:1px solid var(--line); border-radius:16px; background:var(--card-2); overflow:hidden; }
.round-head { padding:18px; border-bottom:1px solid var(--line); display:grid; gap:12px; }
.round-title-line { display:flex; justify-content:space-between; align-items:flex-start; gap:14px; }
.round-title-line h3 { font-family:var(--display); letter-spacing:-.03em; font-size:22px; }
.round-stats { font-family:var(--mono); color:var(--muted); font-size:12px; }
.round-track { height:10px; border-radius:999px; background:var(--soft); overflow:hidden; }
.round-fill { height:100%; width:0; display:block; background:var(--accent); border-radius:inherit; transition:width .2s; }
.task-list { display:grid; gap:12px; padding:18px; }
.test-task { border:1px solid var(--line); border-radius:14px; padding:16px; background:color-mix(in srgb,var(--card) 88%,transparent); display:grid; gap:10px; }
.task-top { display:flex; align-items:flex-start; gap:10px; justify-content:space-between; }
.task-num { color:var(--accent); font-family:var(--mono); font-weight:900; font-size:12px; }

:root { --display:"Unbounded","Manrope",system-ui,sans-serif; --body:"Manrope",system-ui,sans-serif; --mono:"JetBrains Mono",Consolas,monospace; }
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin:0; min-height:100vh; font-family:var(--body); color:var(--text);
  background: radial-gradient(circle at 82% 4%, var(--hero-glow1), transparent 38%), radial-gradient(circle at 8% 38%, var(--hero-glow2), transparent 32%), var(--bg);
  background-attachment: fixed; transition: background .3s, color .3s;
}
a { color: inherit; text-decoration: none; }
h1,h2,h3,h4,p { margin: 0; }
button,input,select,textarea { font: inherit; }
button { cursor: pointer; }
.topbar { position: sticky; top:0; z-index:100; display:flex; align-items:center; gap:16px; padding:10px clamp(18px,3vw,34px); min-height:70px; background:rgba(255,255,255,.92); border-bottom:1px solid rgba(8,19,50,.10); box-shadow:0 10px 30px rgba(8,19,50,.05); backdrop-filter: blur(14px); }
.brand { display:flex; align-items:center; gap:10px; }
.boost-logo-mark { width:34px; height:42px; display:inline-grid; place-items:center; flex:0 0 auto; }
.boost-flame { width:34px; height:34px; display:block; filter:drop-shadow(0 9px 14px rgba(255,105,10,.20)); }
.brand-copy { display:grid; gap:2px; }
.brand-name { font-family:var(--body); font-size:24px; font-weight:900; color:#081332; letter-spacing:-.04em; display:inline-flex; align-items:baseline; gap:0; line-height:1; }
.brand-boost { color:#ff690a; }
.lab-tag { display:inline-grid; place-items:center; min-height:24px; padding:0 7px; border:2px solid #ff690a; border-radius:6px; color:#ff690a; font-size:13px; letter-spacing:.06em; margin-left:2px; font-family:var(--mono); font-weight:800; width:max-content; }
.topbar-nav { display:flex; gap:clamp(22px,4vw,54px); margin-left:clamp(20px,5vw,70px); flex-wrap:wrap; }
.top-link { font-family:var(--body); font-size:16px; font-weight:750; color:#111827; transition:color .18s; }
.top-link:hover,.top-link.active { color:#ff690a; }
.audience-switch { margin-left:auto; display:flex; align-items:center; gap:4px; min-width:218px; height:48px; padding:5px; border:2px solid rgba(8,19,50,.13); border-radius:999px; background:#fff; }
.audience-btn { flex:1; height:38px; border:0; border-radius:999px; background:transparent; color:#111827; font:850 16px/1 var(--body); }
.audience-btn.is-active { background:#ff690a; color:#fff; box-shadow:0 10px 22px rgba(255,105,10,.24); }
.topbar-tools { display:flex; gap:8px; align-items:center; }
.btn-tool { height:34px; min-width:38px; padding:0 10px; border:1px solid rgba(8,19,50,.13); border-radius:999px; background:#fff; color:#111827; font:800 11px/1 var(--mono); letter-spacing:0; display:inline-grid; place-items:center; }
select.btn-tool { width:118px; }
.level-bubble { width:46px; height:46px; display:grid; place-items:center; border:1px solid rgba(8,19,50,.13); border-radius:50%; background:#fff; color:#081332; font-weight:900; }
.menu-btn { width:42px; height:42px; border:0; background:transparent; display:grid; gap:5px; align-content:center; }
.menu-btn span { display:block; height:3px; border-radius:999px; background:#081332; }
.wrap { max-width:none; padding:0 0 78px; }
.hero { border:0; border-radius:0; margin:0; padding:0; min-height:520px; background:#fff; overflow:hidden; }
.hero-inner { display:grid; grid-template-columns:minmax(410px,.82fr) 1.18fr; gap:0; min-height:520px; }
.hero-copy-panel { position:relative; z-index:2; padding:clamp(42px,6vw,72px) 28px clamp(42px,5vw,64px) clamp(28px,4vw,56px); background:linear-gradient(90deg,#fff 0%, rgba(255,255,255,.97) 72%, rgba(255,255,255,0) 100%); }
.hero-eyebrow { color:#ff690a; font-family:var(--body); font-size:19px; font-weight:900; margin-bottom:12px; }
.hero-title { max-width:650px; font-family:var(--body); font-size:clamp(2.85rem,5.5vw,5.1rem); line-height:.96; letter-spacing:-.075em; color:#071433; margin-bottom:18px; font-weight:900; }
.hero-title em { color:#071433; font-style:normal; }
.hero-lead { max-width:570px; color:#3d465d; font-size:20px; line-height:1.48; margin-bottom:28px; }
.hero-meta { display:grid; grid-template-columns:repeat(2,minmax(180px,1fr)); gap:16px; max-width:490px; margin-bottom:26px; }
.info-pill { display:grid; grid-template-columns:46px 1fr; align-items:center; gap:12px; min-height:78px; padding:12px 16px; border:1px solid rgba(8,19,50,.11); border-radius:14px; background:rgba(255,255,255,.82); box-shadow:0 16px 34px rgba(8,19,50,.06); color:#081332; }
.info-icon { width:38px; height:38px; display:grid; place-items:center; border:3px solid #7790bf; border-radius:50%; color:#36578c; font-weight:900; }
.hero-actions { display:flex; gap:10px; flex-wrap:wrap; }
.btn { display:inline-grid; place-items:center; min-height:48px; padding:0 20px; border-radius:14px; border:1px solid var(--line-2); font-family:var(--body); font-size:15px; font-weight:850; transition:transform .16s,border-color .16s,background .16s, opacity .16s; }
.btn:hover { transform:translateY(-1px); border-color:var(--accent); }
.btn.primary { background:#ff690a; border-color:#ff690a; color:#fff; box-shadow:0 16px 26px rgba(255,105,10,.20); }
.btn.ghost { background:#fff; color:#081332; border-color:rgba(8,19,50,.14); }
.btn.small { min-height:34px; padding:0 12px; font-size:13px; border-radius:999px; }
.btn[disabled] { opacity:.45; cursor:not-allowed; transform:none; }
.hero-photo { position:relative; min-height:520px; border:0; border-radius:0; box-shadow:none; background:#fff3e7; overflow:hidden; }
.hero-photo::before { content:""; position:absolute; inset:0 auto 0 0; width:32%; z-index:1; background:linear-gradient(90deg,#fff 0%,rgba(255,255,255,.86) 30%,rgba(255,255,255,0) 100%); }
.hero-img { width:100%; height:100%; min-height:520px; object-fit:cover; object-position:center; display:block; background:var(--card-2); }
.lesson-flow,.learn-panel,.step-tracker,.lesson-score-card { width:min(100% - 56px,1440px); margin-left:auto; margin-right:auto; }
.lesson-flow { margin-top:-34px; margin-bottom:22px; position:relative; z-index:5; border:1px solid rgba(8,19,50,.10); border-radius:22px; background:rgba(255,255,255,.94); box-shadow:0 24px 70px rgba(8,19,50,.08); padding:26px 28px; }
.lesson-flow h2,.learn-panel h2 { font-family:var(--body); font-size:18px; color:#081332; margin-bottom:16px; }
.flow-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:48px; }
.flow-card { position:relative; min-height:128px; border:1px solid rgba(8,19,50,.10); border-radius:16px; background:#fff; padding:26px 18px 18px 86px; display:grid; align-content:center; gap:8px; color:#081332; }
.flow-card:not(:last-child)::after { content:"→"; position:absolute; right:-34px; top:50%; transform:translateY(-50%); color:#617291; font-size:30px; }
.flow-num { position:absolute; left:16px; top:14px; width:28px; height:28px; display:grid; place-items:center; border-radius:50%; background:#ff690a; color:#fff; font-weight:900; }
.flow-icon { position:absolute; left:28px; bottom:24px; color:#ffb21a; font-size:42px; line-height:1; }
.flow-card strong { font-size:15px; }
.flow-card small { color:#374151; line-height:1.45; }
.step-tracker { position:sticky; top:70px; z-index:20; display:grid; grid-template-columns:auto 1fr auto; gap:14px; align-items:center; padding:12px 14px; margin-top:0; margin-bottom:18px; border:1px solid var(--line); border-radius:12px; background:color-mix(in srgb,var(--card) 92%,transparent); backdrop-filter:blur(14px); }
.step-count { font-family:var(--mono); font-size:10px; font-weight:800; color:var(--accent); letter-spacing:.14em; text-transform:uppercase; }
.step-track { height:8px; border-radius:999px; background:var(--soft); overflow:hidden; }
.step-fill { display:block; height:100%; width:10%; background:var(--accent); border-radius:inherit; transition:width .2s; }
.step-name { font-family:var(--mono); font-size:10px; color:var(--muted); letter-spacing:.12em; text-transform:uppercase; }
.lesson-score-card { border:1px solid var(--line); background:color-mix(in srgb,var(--card) 94%,transparent); border-radius:16px; padding:14px 18px; margin-bottom:18px; display:grid; gap:10px; }
.lesson-score-head,.lesson-score-meta { display:flex; justify-content:space-between; gap:14px; align-items:center; color:var(--muted); }
.lesson-score-head strong { color:var(--accent); font-size:24px; }
.lesson-score-track { height:9px; background:var(--soft); border-radius:999px; overflow:hidden; }
.lesson-score-fill { display:block; height:100%; width:0; background:var(--accent); border-radius:inherit; }
.lesson-score-meta { font-family:var(--mono); font-size:11px; flex-wrap:wrap; }
.block,.lesson-foot,.copyright { width:min(100% - 56px,1180px); margin-left:auto; margin-right:auto; }
.block { position:relative; border:1px solid var(--line); border-radius:16px; padding:clamp(20px,3vw,30px); margin-top:18px; margin-bottom:18px; background:color-mix(in srgb,var(--card) 92%,transparent); box-shadow:0 22px 60px rgba(8,19,50,.04); }
.block-head { display:flex; gap:14px; align-items:flex-start; padding-bottom:18px; border-bottom:1px solid var(--line); margin-bottom:18px; }
.block-num { flex:0 0 auto; width:44px; height:44px; border-radius:10px; border:1px solid var(--line-2); display:grid; place-items:center; background:var(--soft); color:var(--accent); font-family:var(--mono); font-size:13px; font-weight:800; }
.block-title-wrap { flex:1; min-width:0; }
.block-kicker { font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--brand); margin-bottom:5px; }
.block-title { font-family:var(--display); font-size:clamp(1.35rem,2.4vw,2rem); line-height:1.05; letter-spacing:-.04em; }
.block-time { flex:0 0 auto; font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.12em; color:var(--faint); border:1px solid var(--line); border-radius:999px; padding:8px 10px; }
.block-intro { color:var(--muted); font-size:15px; line-height:1.66; margin-bottom:18px; max-width:920px; }
.goal-grid,.output-grid,.check-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.info-card,.text-card,.error-card,.round-card,.certificate-shell { border:1px solid var(--line); border-radius:12px; padding:16px 18px; background:var(--card-2); }
.info-card h3,.text-card h3,.error-card h3 { font-family:var(--display); font-size:15px; letter-spacing:-.02em; margin-bottom:8px; }
.info-card p,.text-card p,.error-card p { color:var(--muted); line-height:1.6; font-size:14px; }
.course-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:12px; }
.course-card { position:relative; min-height:132px; border:1px solid var(--line); border-radius:16px; padding:18px 18px 16px; background:var(--card-2); display:grid; gap:10px; }
.course-card.final { border-color:color-mix(in srgb,var(--accent) 50%,var(--line)); background:linear-gradient(135deg,var(--card-2),var(--term-bg)); }
.course-index { width:36px; height:36px; border-radius:999px; display:grid; place-items:center; background:var(--accent); color:var(--accent-on); font-weight:900; font-family:var(--mono); }
.course-card strong { font-family:var(--display); letter-spacing:-.03em; }
.course-card small { color:var(--muted); line-height:1.45; }
.scene-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:14px; }
.scene-card { min-height:198px; border:1px solid var(--line); border-radius:14px; background:var(--card-2); display:grid; align-content:end; position:relative; overflow:hidden; box-shadow:0 18px 34px rgba(8,19,50,.08); }
.scene-card img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition:transform .22s ease; }
.scene-card:hover img { transform:scale(1.03); }
.scene-card::after { content:""; position:absolute; inset:0; background:linear-gradient(180deg,transparent 46%,rgba(0,0,0,.64) 100%); }
.scene-card span { position:relative; z-index:1; margin:12px; width:fit-content; border-radius:999px; padding:7px 10px; background:rgba(255,255,255,.9); font-family:var(--mono); font-size:10px; color:#081332; text-transform:uppercase; letter-spacing:.1em; }
.prompt-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; margin-bottom:14px; }
.prompt-card { border:1px solid var(--line); border-radius:12px; padding:14px 16px; background:var(--card-2); display:grid; gap:8px; }
.prompt-card label { display:flex; gap:10px; align-items:flex-start; line-height:1.45; color:var(--text); }
.prompt-card input[type="checkbox"] { margin-top:3px; accent-color:var(--accent); }
.grammar-table-wrap { overflow-x:auto; border:1px solid var(--line); border-radius:12px; margin-bottom:14px; }
.grammar-table { width:100%; min-width:760px; border-collapse:collapse; background:var(--card-2); }
.grammar-table th,.grammar-table td { padding:14px 16px; border-bottom:1px solid var(--line); border-right:1px solid var(--line); vertical-align:top; text-align:left; }
.grammar-table th:last-child,.grammar-table td:last-child { border-right:none; }
.grammar-table tr:last-child td { border-bottom:none; }
.grammar-table th { font-family:var(--display); font-size:15px; letter-spacing:-.02em; }
.grammar-table .formula { color:var(--accent); font-family:var(--mono); font-size:12px; line-height:1.5; }
.grammar-table .sample { color:var(--muted); line-height:1.55; }
.grammar-rule { border-left:3px solid var(--accent); padding:14px 18px; background:var(--term-bg); border-radius:0 12px 12px 0; color:var(--muted); line-height:1.65; margin-bottom:14px; }
.grammar-rule strong { color:var(--accent); font-weight:800; }
.error-card { border-color:color-mix(in srgb,var(--warn) 45%,var(--line)); }
.bad { color:var(--warn); } .good { color:var(--ok); }
.practice-list { display:grid; gap:12px; margin:0; padding:0; list-style:none; }

.practice-hint { border:1px dashed var(--line-2); background:transparent; color:var(--faint); border-radius:999px; padding:7px 10px; font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; }

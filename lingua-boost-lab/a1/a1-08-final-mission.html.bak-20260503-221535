.test-summary { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:16px; }
.summary-card { border:1px solid var(--line); border-radius:14px; background:var(--card-2); padding:14px; }
.summary-card strong { font-size:24px; color:var(--accent); }
.summary-card small { display:block; color:var(--muted); margin-top:4px; }
.certificate-lock { display:grid; grid-template-columns:1fr 1fr; gap:16px; align-items:start; }
.unlock-list { display:grid; gap:10px; }
.unlock-item { display:flex; gap:10px; align-items:center; padding:12px 14px; border:1px solid var(--line); border-radius:12px; background:var(--card-2); color:var(--muted); }
.unlock-dot { width:22px; height:22px; border-radius:999px; display:grid; place-items:center; background:var(--soft); color:var(--faint); font-weight:900; flex:0 0 auto; }
.unlock-item.done .unlock-dot { background:var(--ok); color:white; }
.unlock-item.done { color:var(--text); border-color:color-mix(in srgb,var(--ok) 60%,var(--line)); }
.certificate-shell { background:linear-gradient(135deg,var(--card) 0%, var(--card-2) 70%, var(--term-bg) 100%); }
.certificate { position:relative; min-height:620px; border:2px solid color-mix(in srgb,var(--accent) 50%,var(--line)); border-radius:28px; padding:48px; background:radial-gradient(circle at 85% 14%, rgba(255,105,10,.12), transparent 30%), radial-gradient(circle at 15% 88%, rgba(122,95,207,.16), transparent 34%), var(--card); overflow:hidden; }
.certificate::before { content:""; position:absolute; inset:22px; border:1px dashed color-mix(in srgb,var(--accent) 45%,var(--line)); border-radius:22px; pointer-events:none; }
.cert-content { position:relative; z-index:1; text-align:center; display:grid; gap:18px; justify-items:center; }
.cert-logo { display:inline-flex; gap:6px; align-items:baseline; font-size:28px; font-weight:900; letter-spacing:-.04em; }
.cert-logo span:last-child { color:var(--accent); }
.cert-kicker { font-family:var(--mono); font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:var(--brand); margin-top:10px; }
.cert-title { font-family:var(--display); font-size:clamp(2.2rem,5vw,4rem); letter-spacing:-.06em; line-height:1; }
.cert-name { font-family:var(--display); font-size:clamp(2rem,4vw,3.4rem); color:var(--accent); border-bottom:2px solid var(--line-2); padding:8px 28px 12px; min-width:min(100%,520px); }
.cert-course { font-size:24px; color:var(--text); font-weight:900; }
.cert-meta-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; width:min(100%,860px); margin-top:14px; }
.cert-meta { border:1px solid var(--line); border-radius:14px; padding:12px; background:var(--card-2); }
.cert-meta small { display:block; color:var(--faint); font-family:var(--mono); font-size:10px; text-transform:uppercase; letter-spacing:.12em; margin-bottom:4px; }
.cert-meta strong { font-size:15px; }
.cert-seal { width:96px; height:96px; border-radius:50%; display:grid; place-items:center; background:var(--accent); color:var(--accent-on); font-size:42px; box-shadow:0 20px 42px color-mix(in srgb,var(--accent) 24%,transparent); }
.lesson-foot { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-top:24px; }
.foot-link { border:1px solid var(--line); border-radius:14px; padding:18px; background:var(--card); display:grid; gap:6px; transition:border-color .16s,transform .16s; }
.foot-link:hover { border-color:var(--accent); transform:translateY(-1px); }
.foot-link.next { text-align:right; }
.foot-meta { font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--brand); }
.foot-title { font-family:var(--display); font-size:18px; font-weight:800; letter-spacing:-.02em; }
.copyright { margin-top:24px; color:var(--faint); font-family:var(--mono); font-size:10px; letter-spacing:.12em; text-transform:uppercase; text-align:center; }

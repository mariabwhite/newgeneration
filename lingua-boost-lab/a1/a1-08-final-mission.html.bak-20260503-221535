/* Lesson 1 design DNA alignment: warm, tactile, reward-heavy Lab shell */
[data-theme="light-lab"] {
  --bg: #ffe9b0;
  --bg-2: #ffd6a0;
  --card: #fffceb;
  --card-2: #fff4d6;
  --text: #2d2b1f;
  --muted: #73552e;
  --faint: #9a7849;
  --accent: #f2b84e;
  --accent-2: #ff9e2f;
  --accent-on: #2d2b1f;
  --brand: #ff7d16;
  --brand-2: #aa6f20;
  --line: rgba(170,111,32,.18);
  --line-2: rgba(170,111,32,.30);
  --line-dot: rgba(170,111,32,.42);
  --hero-glow1: rgba(255,179,71,.26);
  --hero-glow2: rgba(255,125,22,.14);
  --term-bg: rgba(252,226,180,.62);
  --soft: rgba(252,232,193,.72);
  --ok: #3c9e3c;
  --warn: #a6531e;
  --bad: #c2414b;
}
body {
  font-family: "Quicksand", "Manrope", system-ui, sans-serif;
}
[data-theme="light-lab"] body,
html[data-theme="light-lab"] body {
  background:
    radial-gradient(circle at 80% 6%, rgba(255,179,71,.35), transparent 32%),
    radial-gradient(circle at 8% 36%, rgba(255,214,160,.58), transparent 34%),
    linear-gradient(145deg, #ffe9b0 0%, #ffd6a0 100%);
}
.hero {
  background: #fffceb;
}
.hero-copy-panel {
  background: linear-gradient(90deg, rgba(255,252,235,.98) 0%, rgba(255,252,235,.94) 72%, rgba(255,252,235,0) 100%);
}
.hero-title,
.block-title,
.flow-card strong,
.course-card strong,
.cert-title,
.cert-name {
  letter-spacing: 0;
}
.lesson-flow,
.learn-panel,
.lesson-score-card,
.block,
.round-panel,
.test-task,
.certificate,
.certificate-shell {
  border-color: rgba(255,217,102,.72);
  box-shadow: 0 18px 34px rgba(84,48,14,.10);
}
.lesson-flow,
.block,
.certificate-shell {
  border-radius: 34px;
}
.flow-card,
.info-card,
.text-card,
.error-card,
.course-card,
.prompt-card,
.summary-card,
.round-tab,
.test-task,
.certificate {
  border-radius: 24px;
}
.btn,
.choice,
.word-chip,
.sentence-chip,
.round-tab,
.practice-hint {
  border-radius: 999px;
}
.btn.primary {
  background: #f2b84e;
  border-color: #f2b84e;
  color: #2d2b1f;
  box-shadow: 0 6px 0 #a6531e, 0 16px 26px rgba(166,83,30,.16);
}

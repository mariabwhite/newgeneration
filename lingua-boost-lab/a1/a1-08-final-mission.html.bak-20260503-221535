<script>
(()=>{
  const root=document.documentElement;
  const paletteSelect=document.querySelector('[data-palette]');
  const stepBlocks=['goal','course-map','visual-review','grammar-review','mini-mission','mixed-practice','final-project','bonus-test','certificate-unlock','certificate'];
  const storyData={
    kids:['I wake up at seven.','I have a blue school bag.','This is my notebook.','There is a desk in my room.','My bag is under the desk.','The pencils are in the cup.','Put the notebook on the desk.','Can you put it there?'],
    adults:['I work at my desk.','I have a laptop and two notebooks.','This is my coffee mug.','There is a lamp on my desk.','My phone is next to the laptop.','The documents are between the laptop and the lamp.','Put them in the bag.','Can you move it, please?']
  };
  let storyChosen=[];
  let storyChecked=false;
  let currentRound=0;
  const taskState={};
  const testRounds=[
    {title:'Present Simple routines',tasks:[
      {type:'choose',q:'I ___ at seven.',options:['wake up','wakes up'],answer:'wake up'},
      {type:'choose',q:'Alex ___ breakfast.',options:['has','have'],answer:'has'},
      {type:'choose',q:'Mia ___ at her desk.',options:['works','work'],answer:'works'},
      {type:'build',q:'Build the sentence.',words:['I','wake up','at seven'],answer:'I wake up at seven'},
      {type:'build',q:'Build the sentence.',words:['She','has','breakfast'],answer:'She has breakfast'},
      {type:'fix',q:'Fix the mistake: He go to school.',answer:'He goes to school'},
      {type:'match',q:'Match the routine word with the place or time.',pairs:[['wake up','morning'],['brush teeth','bathroom'],['go to school','school']],choices:['bathroom','school','morning']},
      {type:'short',q:'Write one sentence about your morning.',free:true,minWords:3}
    ]},
    {title:'Questions & Negatives',tasks:[
      {type:'choose',q:'___ you have a notebook?',options:['Do','Does'],answer:'Do'},
      {type:'choose',q:'___ Alex wake up early?',options:['Do','Does'],answer:'Does'},
      {type:'choose',q:'I ___ have a TV.',options:["don't","doesn't"],answer:"don't"},
      {type:'choose',q:'Mia ___ have a printer.',options:["don't","doesn't"],answer:"doesn't"},
      {type:'build',q:'Build the question.',words:['Do','you','have','a pencil?'],answer:'Do you have a pencil?'},
      {type:'build',q:'Build the question.',words:['Does','she','work','at home?'],answer:'Does she work at home?'},
      {type:'fix',q:'Fix the mistake: Does Alex has a bag?',answer:'Does Alex have a bag?'},
      {type:'dialogue',q:'Do you have a phone? — Yes, I ___.',options:['do','does'],answer:'do'}
    ]},
    {title:'There is / There are',tasks:[
      {type:'choose',q:'___ a desk in the room.',options:['There is','There are'],answer:'There is'},
      {type:'choose',q:'___ two books on the table.',options:['There is','There are'],answer:'There are'},
      {type:'choose',q:'___ there a lamp?',options:['Is','Are'],answer:'Is'},
      {type:'choose',q:'___ there pencils in the cup?',options:['Is','Are'],answer:'Are'},
      {type:'build',q:'Build the sentence.',words:['There is','a chair','next to the desk.'],answer:'There is a chair next to the desk.'},
      {type:'build',q:'Build the sentence.',words:['There are','three books','on the shelf.'],answer:'There are three books on the shelf.'},
      {type:'fix',q:'Fix the mistake: There are a bed in the room.',answer:'There is a bed in the room.'},
      {type:'visual',q:'Look at the scene. Which sentence is correct?',options:['There is a desk.','There are a desk.'],answer:'There is a desk.',img:{kidsLight:'../assets/a1-08-kids-light-scene-03-where.png',kidsDark:'../assets/a1-08-kids-dark-scene-03-where.png',adultsLight:'../assets/a1-08-adults-light-scene-03-where.png',adultsDark:'../assets/a1-08-adults-dark-scene-03-where.png'}}
    ]},
    {title:'Have / Has',tasks:[
      {type:'choose',q:'I ___ a blue bag.',options:['have','has'],answer:'have'},
      {type:'choose',q:'Alex ___ two books.',options:['have','has'],answer:'has'},
      {type:'choose',q:'Mia ___ a laptop.',options:['have','has'],answer:'has'},
      {type:'choose',q:'We ___ pencils.',options:['have','has'],answer:'have'},
      {type:'choose',q:'Does Alex ___ a lamp?',options:['have','has'],answer:'have'},
      {type:'choose',q:'Mia doesn’t ___ a printer.',options:['have','has'],answer:'have'},
      {type:'fix',q:'Fix the mistake: She doesn’t has a notebook.',answer:"She doesn't have a notebook."},
      {type:'dialogue',q:'Does Mia have a laptop? — Yes, she ___.',options:['does','has'],answer:'does'}
    ]},
    {title:'My / Your / His / Her',tasks:[
      {type:'choose',q:'This is ___ bag.',options:['my','I'],answer:'my'},
      {type:'choose',q:'Is this ___ notebook?',options:['your','you'],answer:'your'},
      {type:'choose',q:'Alex has a book. It is ___ book.',options:['his','her'],answer:'his'},
      {type:'choose',q:'Mia has a pencil. It is ___ pencil.',options:['her','his'],answer:'her'},
      {type:'choose',q:'We have books. These are ___ books.',options:['our','we'],answer:'our'},
      {type:'choose',q:'They have keys. These are ___ keys.',options:['their','they'],answer:'their'},
      {type:'match',q:'Match the person with the possessive word.',pairs:[['Alex','his'],['Mia','her'],['I','my'],['we','our']],choices:['her','our','his','my']},
      {type:'fix',q:'Fix the mistake: This is I laptop.',answer:'This is my laptop.'}
    ]},
    {title:'Where is it? Prepositions',tasks:[
      {type:'visual',q:'The pencils are ___ the cup.',options:['in','on'],answer:'in',img:{kidsLight:'../assets/a1-08-kids-light-scene-03-where.png',kidsDark:'../assets/a1-08-kids-dark-scene-03-where.png',adultsLight:'../assets/a1-08-adults-light-scene-03-where.png',adultsDark:'../assets/a1-08-adults-dark-scene-03-where.png'}},
      {type:'choose',q:'The notebook is ___ the desk.',options:['on','under'],answer:'on'},
      {type:'choose',q:'The bag is ___ the desk.',options:['under','between'],answer:'under'},
      {type:'choose',q:'The football is ___ the chair.',options:['next to','in'],answer:'next to'},
      {type:'choose',q:'The book is ___ two notebooks.',options:['between','behind'],answer:'between'},
      {type:'choose',q:'The toy is ___ the box.',options:['behind','on'],answer:'behind'},
      {type:'build',q:'Build the sentence.',words:['The keys','are','in front of','the bag.'],answer:'The keys are in front of the bag.'},
      {type:'short',q:'Where is the bag? Write: under the desk.',answers:['under the desk']}
    ]},
    {title:'Put it there! Instructions & Requests',tasks:[
      {type:'choose',q:'Put the pencils ___ the cup.',options:['in','under'],answer:'in'},
      {type:'choose',q:'Put the notebook ___ the desk.',options:['on','behind'],answer:'on'},
      {type:'choose',q:'Put the bag ___ the desk.',options:['under','between'],answer:'under'},
      {type:'choose',q:'Move the phone ___ the mug.',options:['next to','in'],answer:'next to'},
      {type:'choose',q:'The pencils are many things. Put ___ in the cup.',options:['it','them'],answer:'them'},
      {type:'choose',q:'The bag is one thing. Put ___ under the desk.',options:['it','them'],answer:'it'},
      {type:'build',q:'Build the request.',words:['Can you','put','it','on','the desk?'],answer:'Can you put it on the desk?'},
      {type:'fix',q:'Fix the mistake: Can you puts it there?',answer:'Can you put it there?'}
    ]},
    {title:'Final Mixed Mission',tasks:[
      {type:'short',q:'Mini-text: Alex has a room. There is a desk. His bag is under the desk. Where is his bag?',answers:['under the desk']},
      {type:'choose',q:'Alex ___ a blue bag.',options:['has','have'],answer:'has'},
      {type:'choose',q:'It is ___ bag.',options:['his','her'],answer:'his'},
      {type:'choose',q:'The bag is ___ the desk.',options:['under','on'],answer:'under'},
      {type:'build',q:'Build the sentence.',words:['There is','a lamp','on the desk.'],answer:'There is a lamp on the desk.'},
      {type:'build',q:'Build the instruction.',words:['Put','the pencils','in','the cup.'],answer:'Put the pencils in the cup.'},
      {type:'dialogue',q:'Do you have a notebook? — Yes, I ___.',options:['do','does'],answer:'do'},
      {type:'short',q:'Write one sentence about your room or workspace.',free:true,minWords:4}
    ]}
  ];

  function enableNoAssetsMode(){
    document.querySelectorAll('img').forEach(img=>{
      const markMissing=()=>{
        img.classList.add('is-missing-asset');
        const host=img.closest('.hero-photo,.scene-card,.visual-frame');
        if(host) host.classList.add('is-missing-asset');
      };
      img.addEventListener('error',markMissing,{once:true});
      if(img.complete && img.naturalWidth===0) markMissing();
    });
  }

  function norm(s){ return (s||'').toLowerCase().replace(/[’]/g,"'").replace(/[“”]/g,'').replace(/[?.!,]/g,'').replace(/\s+/g,' ').trim(); }
  function isDark(){ return ['black-lab','violet'].includes(root.getAttribute('data-theme')); }
  function suffix(){ const a=document.body.dataset.audience||'kids'; return a+(isDark()?'Dark':'Light'); }
  function applyPalette(p){ root.setAttribute('data-theme',p); localStorage.setItem('lesson-palette',p); if(paletteSelect) paletteSelect.value=p; updateImages(); renderRound(currentRound); }
  paletteSelect?.addEventListener('change',e=>applyPalette(e.target.value));
  function updateAudienceText(){ const aud=document.body.dataset.audience||'kids'; document.querySelectorAll('[data-kids][data-adults]').forEach(el=>{ if(el.tagName==='TEXTAREA') el.placeholder=el.dataset[aud]||''; else el.textContent=el.dataset[aud]||el.textContent; }); }
  function updateImages(){ const key=suffix(); const hero=document.querySelector('[data-hero-img]'); if(hero&&hero.dataset[key]) hero.src=hero.dataset[key]; document.querySelectorAll('[data-story-img]').forEach(img=>{ if(img.dataset[key]) img.src=img.dataset[key]; }); }
  function applyAudience(aud){ document.body.dataset.audience=aud; localStorage.setItem('lesson-audience',aud); document.querySelectorAll('[data-audience-btn]').forEach(btn=>btn.classList.toggle('is-active',btn.dataset.audienceBtn===aud)); updateAudienceText(); updateImages(); renderStory(); renderRound(currentRound); updateCertPreview(); updateAllScores(); }
  document.querySelectorAll('[data-audience-btn]').forEach(btn=>btn.addEventListener('click',()=>applyAudience(btn.dataset.audienceBtn)));
  function choiceHandler(e){ const btn=e.currentTarget; const row=btn.closest('.choice-row'); row?.querySelectorAll('.choice').forEach(c=>{c.classList.remove('is-picked'); c.removeAttribute('data-state');}); btn.classList.add('is-picked'); btn.dataset.state=btn.dataset.correct==='true'?'correct':'wrong'; updateAllScores(); }
  function bindStaticChoices(){ document.querySelectorAll('[data-mixed]').forEach(btn=>btn.addEventListener('click',choiceHandler)); document.querySelectorAll('.practice-hint').forEach(btn=>btn.addEventListener('click',function(){ this.textContent=this.dataset.answer||''; this.classList.add('shown'); })); }
  function renderStory(){ storyChosen=[]; storyChecked=false; const aud=document.body.dataset.audience||'kids'; const bank=document.getElementById('storyBank'); const out=document.getElementById('storyOutput'); if(!bank||!out)return; const arr=storyData[aud]; const order=[3,0,6,1,5,2,7,4]; bank.innerHTML=''; order.forEach(i=>{ const b=document.createElement('button'); b.className='sentence-chip'; b.textContent=arr[i]; b.dataset.index=i; b.addEventListener('click',()=>{ if(storyChosen.includes(i)) return; storyChosen.push(i); b.classList.add('is-selected'); updateStoryOutput(); }); bank.appendChild(b); }); updateStoryOutput(); }
  function updateStoryOutput(){ const aud=document.body.dataset.audience||'kids'; const arr=storyData[aud]; const out=document.getElementById('storyOutput'); if(!out)return; out.innerHTML=''; storyChosen.forEach((idx,pos)=>{ const li=document.createElement('li'); li.textContent=arr[idx]; if(storyChecked) li.className=idx===pos?'good':'bad'; out.appendChild(li); }); updateStoryScore(); }
  function updateStoryScore(){ const score=storyChosen.reduce((n,idx,pos)=>n+(idx===pos?1:0),0); document.getElementById('storyScore')&&(document.getElementById('storyScore').textContent=`Score: ${storyChecked?score:0} / 8`); return storyChecked?score:0; }
  document.getElementById('checkStoryBtn')?.addEventListener('click',()=>{ storyChecked=true; updateStoryOutput(); updateAllScores(); });
  document.getElementById('resetStoryBtn')?.addEventListener('click',()=>{ renderStory(); updateAllScores(); });
  function taskId(r,t){ return `r${r}t${t}`; }
  function markTask(id,correct,feedbackEl){ taskState[id]={checked:true,correct:!!correct}; if(feedbackEl){ feedbackEl.textContent=correct?'Correct':'Try again'; feedbackEl.className='task-feedback '+(correct?'good':'bad'); } updateTestUI(); updateAllScores(); }
  function getVisualSrc(img){ if(!img)return ''; return img[suffix()]||img.kidsLight||''; }
  function renderTask(task,r,i){ const id=taskId(r,i); const state=taskState[id]; const typeName={choose:'choose',dialogue:'dialogue',visual:'visual check',build:'build',fix:'fix',match:'match',short:'short answer'}[task.type]||task.type; let html=`<article class="test-task" data-task-id="${id}" data-type="${task.type}"><div class="task-top"><span class="task-num">${String(i+1).padStart(2,'0')}</span><span class="task-type">${typeName}</span></div><div class="task-question">${task.q}</div>`; if(task.type==='visual') html+=`<div class="visual-frame"><img class="visual-mini" src="${getVisualSrc(task.img)}" alt="Visual check image"></div>`;
    if(['choose','dialogue','visual'].includes(task.type)){ html+='<div class="choice-row">'+task.options.map(o=>`<button class="choice test-choice ${state&&state.checked&&o===task.answer?'is-picked':''}" data-answer="${o.replace(/"/g,'&quot;')}">${o}</button>`).join('')+'</div>'; }
    if(task.type==='build'){ html+=`<div class="bank">${task.words.map(w=>`<button class="word-chip test-build-chip" data-word="${w.replace(/"/g,'&quot;')}">${w}</button>`).join('')}</div><div class="build-output" data-build-output>Click words in order.</div><div class="input-line"><button class="btn small primary" data-build-check>Check</button><button class="btn small ghost" data-build-reset>Reset</button></div>`; }
    if(task.type==='fix'){ html+=`<div class="input-line"><input data-test-input placeholder="Correct sentence"><button class="btn small primary" data-input-check>Check</button></div>`; }
    if(task.type==='short'){ html+=`<div class="input-line"><input data-test-input placeholder="Type your answer"><button class="btn small primary" data-input-check>Check</button></div>`; }
    if(task.type==='match'){ html+=`<div class="match-grid">${task.pairs.map((p,idx)=>`<div class="match-row"><strong>${p[0]}</strong><select data-match-select data-correct="${p[1]}"><option value="">Choose...</option>${task.choices.map(c=>`<option value="${c}">${c}</option>`).join('')}</select></div>`).join('')}</div><button class="btn small primary" data-match-check>Check match</button>`; }
    html+=`<div class="task-feedback ${state?.checked?(state.correct?'good':'bad'):''}">${state?.checked?(state.correct?'Correct':'Try again'):''}</div></article>`; return html; }
  function renderRound(r){ currentRound=Math.max(0,Math.min(testRounds.length-1,r)); const round=testRounds[currentRound]; document.getElementById('roundKicker').textContent=`Round ${currentRound+1} / 8`; document.getElementById('roundTitle').textContent=round.title; document.getElementById('taskList').innerHTML=round.tasks.map((t,i)=>renderTask(t,currentRound,i)).join(''); renderRoundTabs(); bindDynamicTasks(); updateTestUI(); }
  function renderRoundTabs(){ const list=document.getElementById('roundList'); if(!list)return; list.innerHTML=testRounds.map((r,idx)=>{ const c=roundCompleted(idx); const s=roundScore(idx); return `<button class="round-tab ${idx===currentRound?'is-active':''} ${c?'is-done':''}" data-round-tab="${idx}"><strong>${idx+1}. ${r.title}</strong><small>${s} / 8 · ${c?'completed':'in progress'}</small></button>`; }).join(''); list.querySelectorAll('[data-round-tab]').forEach(btn=>btn.addEventListener('click',()=>renderRound(+btn.dataset.roundTab))); }
  function bindDynamicTasks(){ document.querySelectorAll('.test-choice').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const id=article.dataset.taskId; const roundIdx=+id.match(/r(\d+)t/)[1]; const taskIdx=+id.match(/t(\d+)/)[1]; const answer=testRounds[roundIdx].tasks[taskIdx].answer; article.querySelectorAll('.test-choice').forEach(b=>{ b.classList.remove('is-picked'); b.removeAttribute('data-state'); }); btn.classList.add('is-picked'); const correct=norm(btn.dataset.answer)===norm(answer); btn.dataset.state=correct?'correct':'wrong'; markTask(id,correct,article.querySelector('.task-feedback')); }));
    document.querySelectorAll('.test-build-chip').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const out=article.querySelector('[data-build-output]'); const words=(out.dataset.words?JSON.parse(out.dataset.words):[]); words.push(btn.dataset.word); out.dataset.words=JSON.stringify(words); out.textContent=words.join(' '); btn.disabled=true; }));
    document.querySelectorAll('[data-build-reset]').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const out=article.querySelector('[data-build-output]'); out.dataset.words='[]'; out.textContent='Click words in order.'; article.querySelectorAll('.test-build-chip').forEach(b=>b.disabled=false); article.querySelector('.task-feedback').textContent=''; }));
    document.querySelectorAll('[data-build-check]').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const id=article.dataset.taskId; const r=+id.match(/r(\d+)t/)[1]; const t=+id.match(/t(\d+)/)[1]; const out=article.querySelector('[data-build-output]'); const text=(JSON.parse(out.dataset.words||'[]')).join(' '); const correct=norm(text)===norm(testRounds[r].tasks[t].answer); markTask(id,correct,article.querySelector('.task-feedback')); }));
    document.querySelectorAll('[data-input-check]').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const id=article.dataset.taskId; const r=+id.match(/r(\d+)t/)[1]; const t=+id.match(/t(\d+)/)[1]; const task=testRounds[r].tasks[t]; const val=article.querySelector('[data-test-input]').value; let correct=false; if(task.free){ correct=norm(val).split(' ').filter(Boolean).length>=(task.minWords||3); } else if(task.answers){ correct=task.answers.some(a=>norm(val).includes(norm(a))); } else { correct=norm(val)===norm(task.answer); } markTask(id,correct,article.querySelector('.task-feedback')); }));
    document.querySelectorAll('[data-match-check]').forEach(btn=>btn.addEventListener('click',()=>{ const article=btn.closest('.test-task'); const id=article.dataset.taskId; const selects=article.querySelectorAll('[data-match-select]'); const correct=[...selects].every(s=>norm(s.value)===norm(s.dataset.correct)); markTask(id,correct,article.querySelector('.task-feedback')); })); }
  function roundScore(r){ return testRounds[r].tasks.reduce((n,_,i)=>n+(taskState[taskId(r,i)]?.correct?1:0),0); }
  function roundDoneCount(r){ return testRounds[r].tasks.reduce((n,_,i)=>n+(taskState[taskId(r,i)]?.checked?1:0),0); }
  function roundCompleted(r){ return roundDoneCount(r)===testRounds[r].tasks.length; }
  function totalTestScore(){ return testRounds.reduce((n,_,r)=>n+roundScore(r),0); }
  function totalTestDone(){ return testRounds.reduce((n,round,r)=>n+roundDoneCount(r),0); }
  function allRoundsCompleted(){ return testRounds.every((_,r)=>roundCompleted(r)); }
  function updateTestUI(){ const rs=roundScore(currentRound), rd=roundDoneCount(currentRound); document.getElementById('roundScore').textContent=`${rs} / 8`; document.getElementById('roundFill').style.width=`${(rd/8)*100}%`; document.getElementById('roundNote').textContent=roundCompleted(currentRound)?`Round complete. Score: ${rs} / 8.`:`Complete all tasks in this round. Completed: ${rd} / 8.`; document.getElementById('prevRoundBtn').disabled=currentRound===0; document.getElementById('nextRoundBtn').disabled=currentRound===testRounds.length-1; document.getElementById('testScoreBig').textContent=`${totalTestScore()} / 64`; document.getElementById('testProgressBig').textContent=`${totalTestDone()} / 64`; document.getElementById('testStatusBig').textContent=certificateReady(false)?'Ready':(totalTestScore()>=45?'Almost':'Locked'); renderRoundTabs(); updateUnlockUI(); }
  document.getElementById('prevRoundBtn')?.addEventListener('click',()=>renderRound(currentRound-1));
  document.getElementById('nextRoundBtn')?.addEventListener('click',()=>renderRound(currentRound+1));
  function mixedScore(){ return document.querySelectorAll('#mixed-practice .choice.is-picked[data-correct="true"]').length; }
  function projectComplete(){ const text=document.querySelector('[data-final-draft]')?.value||''; const words=norm(text).split(' ').filter(Boolean).length; const checks=document.querySelectorAll('[data-final]:checked').length; return words>=45 && checks>=5; }
  function certificateReady(requireName=true){ const nameOk=!requireName || (document.getElementById('studentName')?.value.trim().length>=2); return allRoundsCompleted() && totalTestScore()>=45 && projectComplete() && nameOk; }
  function updateUnlockUI(){ const conditions=[['unlockRounds',allRoundsCompleted()],['unlockScore',totalTestScore()>=45],['unlockProject',projectComplete()],['unlockName',(document.getElementById('studentName')?.value.trim().length||0)>=2]]; conditions.forEach(([id,ok])=>{ const el=document.getElementById(id); if(el){ el.classList.toggle('done',ok); el.querySelector('.unlock-dot').textContent=ok?'✓':'•'; } }); const ready=certificateReady(true); document.getElementById('generateCertBtn').disabled=!ready; const msg=document.getElementById('certMessage'); if(msg) msg.textContent=ready?'Certificate is unlocked. Generate it now.':'Complete all conditions to unlock your certificate.'; }
  function updateCertPreview(){ const aud=document.body.dataset.audience||'kids'; document.getElementById('certAudienceTitle').textContent=aud==='kids'?'A1 English Explorer Certificate':'A1 English Foundation Certificate'; document.getElementById('certScore').textContent=`${totalTestScore()} / 64`; }
  function generateCert(){ if(!certificateReady(true)) { updateUnlockUI(); return; } const name=document.getElementById('studentName').value.trim(); const date=new Date(); const y=date.getFullYear(), m=String(date.getMonth()+1).padStart(2,'0'), d=String(date.getDate()).padStart(2,'0'); const id=`LB-A1-${y}${m}${d}-${Math.floor(1000+Math.random()*9000)}`; document.getElementById('certName').textContent=name; document.getElementById('certScore').textContent=`${totalTestScore()} / 64`; document.getElementById('certDate').textContent=`${d}.${m}.${y}`; document.getElementById('certId').textContent=id; document.getElementById('printCertBtn').disabled=false; document.getElementById('certMessage').textContent='Certificate generated. You can print or save it as PDF.'; updateCertPreview(); document.getElementById('certificate').scrollIntoView({behavior:'smooth'}); }
  document.getElementById('generateCertBtn')?.addEventListener('click',generateCert);
  document.getElementById('printCertBtn')?.addEventListener('click',()=>window.print());
  document.getElementById('studentName')?.addEventListener('input',()=>{ updateUnlockUI(); updateCertPreview(); });
  document.querySelector('[data-final-draft]')?.addEventListener('input',()=>{ updateAllScores(); updateUnlockUI(); });
  document.querySelectorAll('[data-final], [data-obs]').forEach(i=>i.addEventListener('change',()=>{ updateAllScores(); updateUnlockUI(); }));
  function updateAllScores(){ const obs=Math.min(document.querySelectorAll('[data-obs]:checked').length,8); const story=updateStoryScore(); const mix=mixedScore(); const project=projectComplete()?12:0; const test=totalTestScore(); const max=8+8+16+12+64; const points=obs+story+mix+project+test; const score=Math.round((points/max)*100); document.querySelector('[data-lesson-score]').textContent=`${score}%`; document.querySelector('[data-lesson-score-fill]').style.width=`${score}%`; document.querySelector('[data-module-progress-count]').textContent=`${Math.floor(score/10)} / 10`; updateUnlockUI(); updateCertPreview(); }
  function updateStep(){ let active=0; stepBlocks.forEach((id,i)=>{ const b=document.getElementById(id); if(b&&b.getBoundingClientRect().top<window.innerHeight*.42) active=i; }); document.querySelector('[data-step-current]').textContent=String(active+1).padStart(2,'0'); document.querySelector('[data-step-fill]').style.width=`${((active+1)/stepBlocks.length)*100}%`; document.querySelector('[data-step-name]').textContent=stepBlocks[active].replace(/-/g,' '); }
  window.addEventListener('scroll',updateStep);
  document.querySelectorAll('img').forEach(img=>{ img.addEventListener('error',()=>{ img.style.background='linear-gradient(135deg,var(--card-2),var(--soft))'; }); });
  let mediaRecorder,chunks=[]; const startBtn=document.querySelector('[data-record-start]'),stopBtn=document.querySelector('[data-record-stop]'),audioEl=document.querySelector('[data-record-audio]'),recordDot=document.querySelector('[data-record-dot]');
  startBtn?.addEventListener('click',async()=>{ if(!navigator.mediaDevices?.getUserMedia) return; const stream=await navigator.mediaDevices.getUserMedia({audio:true}); chunks=[]; mediaRecorder=new MediaRecorder(stream); mediaRecorder.addEventListener('dataavailable',e=>{if(e.data.size>0)chunks.push(e.data);}); mediaRecorder.addEventListener('stop',()=>{ const blob=new Blob(chunks,{type:'audio/webm'}); if(audioEl) audioEl.src=URL.createObjectURL(blob); stream.getTracks().forEach(t=>t.stop()); }); mediaRecorder.start(); startBtn.disabled=true; stopBtn?.removeAttribute('disabled'); recordDot?.classList.add('is-recording'); });
  stopBtn?.addEventListener('click',()=>{ mediaRecorder?.stop(); stopBtn.disabled=true; startBtn?.removeAttribute('disabled'); recordDot?.classList.remove('is-recording'); });
  enableNoAssetsMode();
  bindStaticChoices(); applyPalette(localStorage.getItem('lesson-palette')||'light-lab'); applyAudience(localStorage.getItem('lesson-audience')||'kids'); renderStory(); renderRound(0); updateStep(); updateAllScores();
})();
</script>

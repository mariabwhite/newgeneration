        if(hero&&src) hero.src=src;
        document.querySelectorAll("[data-story-img]").forEach((img,idx)=>{
          const key=img.dataset[`${audience}Src`];
          if(key) img.src=key;
        });
        const obsSpans=document.querySelectorAll("[data-obs] span");
        obsSpans.forEach(span=>{ const txt=span.closest("[data-obs]")?.dataset[audience]; if(txt) span.innerText=txt; });
        const scriptP=document.getElementById("readingScript");
        if(scriptP&&scriptP.dataset[audience]) scriptP.innerText=scriptP.dataset[audience];
      }
      function applyAudience(aud){
        document.body.dataset.audience=aud;
        localStorage.setItem("lesson-audience",aud);
        document.querySelectorAll("[data-audience-btn]").forEach(btn=>btn.classList.toggle("is-active",btn.dataset.audienceBtn===aud));
        const lead=document.querySelector(".friendly-lead");
        if(lead&&lead.dataset[aud]) lead.innerText=lead.dataset[aud];
        updateHeroImages();
        updateReadingChoices();
      }
      function updateReadingChoices(){
        const audience=document.body.dataset.audience||"kids";
        const items=document.querySelectorAll("#text .practice-item .practice-q");
        if(audience==="adults"){
          if(items[0]) items[0].innerHTML="Does Mia have a small workspace? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[1]) items[1].innerHTML="Does Mia have a desk near the window? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[2]) items[2].innerHTML="Does Mia have two notebooks? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[4]) items[4].innerHTML="Does Mia have a printer? <span class='choice-row'><button class='choice'>Yes</button><button class='choice' data-correct='true'>No</button></span>";
          if(items[5]) items[5].innerHTML="Does Mia have many documents on the table? <span class='choice-row'><button class='choice'>Yes</button><button class='choice' data-correct='true'>No</button></span>";
          if(items[6]) items[6].innerHTML="Does Mia have a coffee mug? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
        } else {
          if(items[0]) items[0].innerHTML="Does Alex have a small room? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[1]) items[1].innerHTML="Does Alex have a desk near the window? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[2]) items[2].innerHTML="Does Alex have two books? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
          if(items[4]) items[4].innerHTML="Does Alex have a TV in his room? <span class='choice-row'><button class='choice'>Yes</button><button class='choice' data-correct='true'>No</button></span>";
          if(items[5]) items[5].innerHTML="Does Alex have many toys on the floor? <span class='choice-row'><button class='choice'>Yes</button><button class='choice' data-correct='true'>No</button></span>";
          if(items[6]) items[6].innerHTML="Does Alex have a football? <span class='choice-row'><button class='choice' data-correct='true'>Yes</button><button class='choice'>No</button></span>";
        }
        document.querySelectorAll("#text .choice").forEach(btn=>btn.removeEventListener("click",choiceHandler));
        document.querySelectorAll("#text .choice").forEach(btn=>btn.addEventListener("click",choiceHandler));
        updateScore();
      }
      function choiceHandler(e){
        const row=e.currentTarget.closest(".choice-row");
        row?.querySelectorAll(".choice").forEach(c=>{c.classList.remove("is-picked");c.removeAttribute("data-state");});
        e.currentTarget.classList.add("is-picked");
        e.currentTarget.dataset.state=e.currentTarget.dataset.correct==="true"?"correct":"wrong";
        updateScore();
      }
      applyAudience(localStorage.getItem("lesson-audience")||"kids");
      document.querySelectorAll("[data-audience-btn]").forEach(btn=>btn.addEventListener("click",()=>applyAudience(btn.dataset.audienceBtn)));
      
      document.querySelectorAll(".choice").forEach(btn=>btn.addEventListener("click",choiceHandler));
      document.querySelectorAll(".practice-hint").forEach(btn=>btn.addEventListener("click",function(){ this.textContent=this.dataset.answer||""; this.classList.add("shown"); }));
      let selectedWord="";
      document.querySelectorAll(".word-chip").forEach(chip=>{ chip.addEventListener("click",()=>{ document.querySelectorAll(".word-chip").forEach(c=>c.classList.remove("is-selected")); chip.classList.add("is-selected"); selectedWord=chip.textContent.trim(); }); chip.addEventListener("dragstart",e=>{ selectedWord=chip.textContent.trim(); e.dataTransfer?.setData("text/plain",selectedWord); }); });
      document.querySelectorAll("[data-drop]").forEach(slot=>{ function fill(v){ if(!v)return; slot.textContent=v; slot.classList.add("filled"); const exp=slot.dataset.expected; const isCorrect=exp&&v.trim().toLowerCase()===exp.toLowerCase(); slot.classList.toggle("is-correct",isCorrect); updateScore(); } slot.addEventListener("click",()=>fill(selectedWord)); slot.addEventListener("dragover",e=>e.preventDefault()); slot.addEventListener("drop",e=>{ e.preventDefault(); fill(e.dataTransfer?.getData("text/plain")||selectedWord); }); });
      
      function updateScore(){
        const correctChoices=document.querySelectorAll("#guided .choice.is-picked[data-correct='true']").length;
        const correctDrops=document.querySelectorAll("[data-drop].filled.is-correct").length;
        const obsChecks=document.querySelectorAll("[data-obs]:checked").length;
        const readChecks=document.querySelectorAll("#text .choice.is-picked[data-correct='true']").length;
        const finalChecks=document.querySelectorAll("[data-final]:checked").length;
        const draft=document.querySelector("[data-final-draft]")?.value.trim()||"";
        const draftDone=draft.split(/\s+/).length>=20;
        const points=correctChoices+correctDrops+Math.min(obsChecks,4)+readChecks+Math.min(finalChecks,4)+(draftDone?4:0);
        const max=16+8+4+8+4+4;
        const score=Math.round((points/max)*100);
        document.querySelector("[data-lesson-score]").textContent=`${score}%`;
        document.querySelector("[data-lesson-score-fill]").style.width=`${score}%`;
        const comp=Math.floor(score/12.5);
        document.querySelector("[data-module-progress-count]").textContent=`${comp} / 8`;
      }
      document.querySelectorAll("input[type='checkbox']").forEach(i=>i.addEventListener("change",updateScore));
      document.querySelector("[data-final-draft]")?.addEventListener("input",updateScore);
      updateScore();
      
      const stepBlocks=["goal","input","vocab","focus","guided","active","text","final-task"];
      function updateStep(){ let active=0; stepBlocks.forEach((id,i)=>{ const b=document.getElementById(id); if(b&&b.getBoundingClientRect().top<window.innerHeight*0.42) active=i; }); document.querySelector("[data-step-current]")&&(document.querySelector("[data-step-current]").textContent=String(active+1).padStart(2,"0")); document.querySelector("[data-step-fill]")&&(document.querySelector("[data-step-fill]").style.width=`${((active+1)/stepBlocks.length)*100}%`); document.querySelector("[data-step-name]")&&(document.querySelector("[data-step-name]").textContent=stepBlocks[active].charAt(0).toUpperCase()+stepBlocks[active].slice(1)); }
      window.addEventListener("scroll",updateStep); updateStep();
      
      let mediaRecorder,chunks=[];
      const startBtn=document.querySelector("[data-record-start]"),stopBtn=document.querySelector("[data-record-stop]"),audioEl=document.querySelector("[data-record-audio]"),recordDot=document.querySelector("[data-record-dot]");
      startBtn?.addEventListener("click",async()=>{ if(!navigator.mediaDevices?.getUserMedia) return; const stream=await navigator.mediaDevices.getUserMedia({audio:true}); chunks=[]; mediaRecorder=new MediaRecorder(stream); mediaRecorder.addEventListener("dataavailable",e=>{ if(e.data.size>0) chunks.push(e.data); }); mediaRecorder.addEventListener("stop",()=>{ const blob=new Blob(chunks,{type:"audio/webm"}); if(audioEl) audioEl.src=URL.createObjectURL(blob); stream.getTracks().forEach(t=>t.stop()); }); mediaRecorder.start(); startBtn.disabled=true; stopBtn?.removeAttribute("disabled"); recordDot?.classList.add("is-recording"); });
      stopBtn?.addEventListener("click",()=>{ mediaRecorder?.stop(); stopBtn.disabled=true; startBtn?.removeAttribute("disabled"); recordDot?.classList.remove("is-recording"); });
      
      document.getElementById("listenBtn")?.addEventListener("click",()=>{ const text=document.getElementById("readingScript")?.innerText; if(text&&window.speechSynthesis){ window.speechSynthesis.cancel(); const utter=new SpeechSynthesisUtterance(text); utter.lang="en-US"; utter.rate=0.9; window.speechSynthesis.speak(utter); } });
      let textVisible=true;
      document.getElementById("showTextBtn")?.addEventListener("click",()=>{ const card=document.getElementById("readingCard"); if(card){ textVisible=!textVisible; card.style.display=textVisible?"block":"none"; document.getElementById("showTextBtn").innerText=textVisible?"Hide text":"Show text"; } });
      updateReadingChoices();
    })();
  </script>
</body>
</html>




:root {
  --display: "Unbounded", "Manrope", system-ui, sans-serif;
  --body: "Manrope", system-ui, sans-serif;
  --mono: "JetBrains Mono", Consolas, monospace;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0; min-height: 100vh; font-family: var(--body); color: var(--text);
  background: radial-gradient(circle at 82% 4%, var(--hero-glow1), transparent 38%), radial-gradient(circle at 8% 38%, var(--hero-glow2), transparent 32%), var(--bg);
  background-attachment: fixed; transition: background 0.3s, color 0.3s;
}
a { color: inherit; text-decoration: none; }
h1, h2, h3, h4, p { margin: 0; }
button, input, select, textarea { font: inherit; }
.topbar {
  position: sticky; top: 0; z-index: 100; display: flex; align-items: center; gap: 16px;
  padding: 10px clamp(16px, 3vw, 28px); background: color-mix(in srgb, var(--bg) 88%, transparent);
  border-bottom: 1px solid var(--line); backdrop-filter: blur(14px); min-height: 56px;
}
.brand { display: flex; align-items: center; gap: 12px; }
.brand-mark {
  width: 36px; height: 36px; border: 1px solid var(--line-2); border-radius: 8px;
  display: grid; place-items: center; background: var(--soft); position: relative;
}
.brand-mark::before { content: "L"; font-family: var(--display); font-size: 20px; font-weight: 900; color: var(--accent); line-height: 1; letter-spacing: -0.04em; }
.brand-mark::after { content: ""; position: absolute; right: 4px; bottom: 4px; width: 5px; height: 5px; border-radius: 50%; background: var(--brand); }
.brand-copy { display: grid; gap: 2px; }
.brand-name { font-family: var(--display); font-size: 14px; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
.brand-tag { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); }
.topbar-nav { display: flex; gap: clamp(12px, 2vw, 22px); margin-left: 12px; flex-wrap: wrap; }
.top-link { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); transition: color 0.18s; }
.top-link:hover, .top-link.active { color: var(--accent); }
.topbar-tools { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.btn-tool {
  height: 32px; min-width: 38px; padding: 0 10px; border: 1px solid var(--line-2); border-radius: 8px;
  background: var(--card); color: var(--muted); font: 800 11px/1 var(--mono); letter-spacing: 0.08em; cursor: pointer;
  display: inline-grid; place-items: center; transition: all 0.16s;
}
select.btn-tool { width: 118px; }
.btn-tool:hover { border-color: var(--accent); color: var(--accent); }
.btn-tool.is-active { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
.wrap { max-width: 1240px; margin: 0 auto; padding: 32px clamp(16px, 3vw, 28px) 80px; }
.hero {
  position: relative; border: 1px solid var(--line); border-radius: 18px; padding: clamp(26px, 5vw, 56px); margin-bottom: 18px;
  background: radial-gradient(circle at 88% 14%, var(--hero-glow1), transparent 42%), radial-gradient(circle at 8% 88%, var(--hero-glow2), transparent 50%), var(--card);
  overflow: hidden;
}
.hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.28fr 0.92fr; gap: 40px; align-items: center; }
.hero-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px; }
.hero-eyebrow::before { content: "$ "; color: var(--accent); }
.hero-title { font-family: var(--display); font-size: clamp(2.05rem, 5vw, 4.25rem); line-height: 0.96; letter-spacing: -0.05em; margin-bottom: 18px; }
.hero-title em { font-style: normal; color: var(--accent); }
.hero-lead { color: var(--muted); font-size: clamp(15px, 1.4vw, 17px); line-height: 1.7; max-width: 760px; margin-bottom: 20px; }
.hero-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
.pill { display: inline-grid; place-items: center; min-height: 28px; padding: 6px 10px; border: 1px solid var(--line-2); border-radius: 999px; background: var(--soft); color: var(--muted); font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.btn {
  display: inline-grid; place-items: center; min-height: 42px; padding: 0 18px; border-radius: 8px;
  border: 1px solid var(--line-2); font-family: var(--mono); font-size: 11px; font-weight: 800;
  letter-spacing: 0.12em; text-transform: uppercase; transition: transform 0.16s, border-color 0.16s, background 0.16s;
}
.btn:hover { transform: translateY(-1px); border-color: var(--accent); }
.btn.primary { background: var(--accent); color: var(--accent-on); border-color: var(--accent); }
.btn.ghost { background: var(--soft); color: var(--text); }
.hero-photo { position: relative; min-height: 320px; border-radius: 16px; border: 1px solid var(--line-2); overflow: hidden; background: var(--card-2); box-shadow: 0 30px 80px -28px var(--hero-glow1); }
.hero-img { width: 100%; height: 100%; min-height: inherit; object-fit: cover; display: block; }
.scene-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 14px; }
.scene-card {
  min-height: 188px; border: 1px solid var(--line); border-radius: 14px; background: var(--card-2);
  display: grid; align-content: end; position: relative; overflow: hidden; box-shadow: 0 18px 34px rgba(8,19,50,0.08);
}
.scene-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.22s ease; }
.scene-card:hover img { transform: scale(1.03); }
.scene-card::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 46%, rgba(0,0,0,0.58) 100%); }
.scene-card span { position: relative; z-index: 1; margin: 12px; width: fit-content; border-radius: 999px; padding: 7px 10px; background: rgba(255,255,255,0.9); font-family: var(--mono); font-size: 10px; color: #081332; text-transform: uppercase; letter-spacing: 0.1em; }
.prompt-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin-bottom: 14px; }
.prompt-card { border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; background: var(--card-2); display: grid; gap: 8px; }
.prompt-card label { display: flex; gap: 10px; align-items: flex-start; line-height: 1.45; color: var(--text); }
.prompt-card input[type="checkbox"] { margin-top: 3px; accent-color: var(--accent); }
.now-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
.now-item { border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; background: var(--card-2); }
.now-item label { display: flex; gap: 10px; align-items: flex-start; color: var(--muted); line-height: 1.45; }
.now-item input { margin-top: 3px; accent-color: var(--ok); }
.step-tracker {
  position: sticky; top: 56px; z-index: 20; display: grid; grid-template-columns: auto 1fr auto; gap: 14px;
  align-items: center; padding: 12px 14px; margin: 0 0 18px; border: 1px solid var(--line);
  border-radius: 12px; background: color-mix(in srgb, var(--card) 92%, transparent); backdrop-filter: blur(14px);
}
.step-count { font-family: var(--mono); font-size: 10px; font-weight: 800; color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase; }
.step-track { height: 8px; border-radius: 999px; background: var(--soft); overflow: hidden; }
.step-fill { height: 100%; width: 12.5%; background: var(--accent); border-radius: inherit; transition: width 0.2s; }
.step-name { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; }
.block-nav { display: flex; justify-content: flex-end; gap: 10px; margin-top: 18px; }
.bank.interactive { gap: 10px; margin-bottom: 18px; }
.word-chip {
  display: inline-grid; place-items: center; min-height: 32px; padding: 7px 11px; border-radius: 999px;
  border: 1px solid var(--line-2); background: var(--card-2); color: var(--text);
  font-family: var(--mono); font-size: 11px; font-weight: 800; cursor: grab;
}
.word-chip.is-selected { border-color: var(--accent); color: var(--accent); }
.drop-slot {
  display: inline-grid; place-items: center; min-width: 128px; min-height: 30px; padding: 3px 10px;
  border: 1px dashed var(--accent); border-radius: 999px; color: var(--faint);
}
.drop-slot.filled { border-style: solid; color: var(--text); background: var(--soft); }
.recorder { display: grid; gap: 12px; padding: 16px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2); margin-top: 14px; }
.recorder-controls { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
.record-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--faint); display: inline-block; }
.record-dot.is-recording { background: #ff4d5f; box-shadow: 0 0 0 6px rgba(255,77,95,0.16); }
.block {
  position: relative; border: 1px solid var(--line); border-radius: 16px; padding: clamp(20px, 3vw, 30px);
  margin: 18px 0; background: color-mix(in srgb, var(--card) 92%, transparent);
}
.block-head { display: flex; gap: 14px; align-items: flex-start; padding-bottom: 18px; border-bottom: 1px solid var(--line); margin-bottom: 18px; }
.block-num { flex: 0 0 auto; width: 44px; height: 44px; border-radius: 10px; border: 1px solid var(--line-2); display: grid; place-items: center; background: var(--soft); color: var(--accent); font-family: var(--mono); font-size: 13px; font-weight: 800; }
.block-title-wrap { flex: 1; min-width: 0; }
.block-kicker { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--brand); margin-bottom: 5px; }
.block-title { font-family: var(--display); font-size: clamp(1.35rem, 2.4vw, 2rem); line-height: 1.05; letter-spacing: -0.04em; }
.block-time { flex: 0 0 auto; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.12em; color: var(--faint); border: 1px solid var(--line); border-radius: 999px; padding: 8px 10px; }
.block-intro { color: var(--muted); font-size: 15px; line-height: 1.66; margin-bottom: 18px; max-width: 860px; }
.goal-grid, .focus-grid, .output-grid, .check-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.info-card, .text-card, .error-card { border: 1px solid var(--line); border-radius: 12px; padding: 16px 18px; background: var(--card-2); }
.info-card h3, .text-card h3, .error-card h3 { font-family: var(--display); font-size: 15px; letter-spacing: -0.02em; margin-bottom: 8px; }
.info-card p, .text-card p, .error-card p { color: var(--muted); line-height: 1.6; font-size: 14px; }
.vocab-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 12px; }
.vocab-card { padding: 16px 18px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2); transition: transform 0.16s, border-color 0.16s; }
.vocab-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.vocab-en { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
.vocab-word { font-family: var(--display); font-size: 18px; font-weight: 800; letter-spacing: -0.02em; }
.vocab-ipa { font-family: var(--mono); font-size: 11px; color: var(--faint); }
.vocab-ru { color: var(--muted); font-size: 14px; line-height: 1.5; }
.vocab-example { margin-top: 10px; color: var(--text); font-size: 13px; line-height: 1.5; }
.grammar-table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 12px; margin-bottom: 14px; }
.grammar-table { width: 100%; min-width: 760px; border-collapse: collapse; background: var(--card-2); }
.grammar-table th, .grammar-table td { padding: 14px 16px; border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); vertical-align: top; text-align: left; }
.grammar-table th:last-child, .grammar-table td:last-child { border-right: none; }
.grammar-table tr:last-child td { border-bottom: none; }
.grammar-table th { font-family: var(--display); font-size: 15px; letter-spacing: -0.02em; color: var(--text); }
.grammar-table .formula { color: var(--accent); font-family: var(--mono); font-size: 12px; line-height: 1.5; }
.grammar-table .sample { color: var(--muted); line-height: 1.55; }
.grammar-rule { border-left: 3px solid var(--accent); padding: 14px 18px; background: var(--term-bg); border-radius: 0 12px 12px 0; color: var(--muted); line-height: 1.65; margin-bottom: 14px; }
.grammar-rule strong { color: var(--accent); font-weight: 800; }
.error-card { border-color: color-mix(in srgb, var(--warn) 45%, var(--line)); }
.bad { color: var(--warn); }
.good { color: var(--ok); }
.practice-list { display: grid; gap: 12px; margin: 0; padding: 0; list-style: none; }
.practice-item {
  display: grid; grid-template-columns: 34px 1fr auto; gap: 14px; align-items: center;
  padding: 14px 16px; border: 1px solid var(--line); border-radius: 12px; background: var(--card-2);
}
.practice-num { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--accent); }
.practice-q { font-size: 15px; line-height: 1.5; }
.choice-row { display: flex; gap: 8px; flex-wrap: wrap; }
.choice {
  border: 1px solid var(--line-2); border-radius: 999px; padding: 7px 11px; background: var(--soft);
  color: var(--muted); cursor: pointer; font-family: var(--mono); font-size: 11px; font-weight: 800;
}
.choice:hover, .choice.is-picked { border-color: var(--accent); color: var(--accent); }
.practice-hint {
  border: 1px dashed var(--line-2); background: transparent; color: var(--faint); border-radius: 999px;
  padding: 7px 10px; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; cursor: pointer;
}
.practice-hint:hover { color: var(--brand); border-color: var(--brand); }

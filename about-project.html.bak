</head>
<body data-page="about">

<header class="topbar">
  <a class="brand" href="index.html" aria-label="New Generation English">
    <div class="brand-mark">N</div>
    <div>
      <div class="brand-name"><span>NG ENGLISH</span></div>
      <div class="brand-sub">nge В· since 2023</div>
    </div>
  </a>


<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Рћ РїСЂРѕРµРєС‚Рµ New Generation English: Р±РёРѕРіСЂР°С„РёСЏ РїСЂРµРїРѕРґР°РІР°С‚РµР»СЏ, РёРґРµСЏ РЅРµР№СЂРѕС€РєРѕР»С‹, РґРѕРєСѓРјРµРЅС‚С‹ Рё РєР°Р±РёРЅРµС‚С‹ РІРЅСѓС‚СЂРё РѕР±СЂР°Р·РѕРІР°С‚РµР»СЊРЅРѕР№ СЌРєРѕСЃРёСЃС‚РµРјС‹.">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23000'/><text y='.9em' x='10' font-size='80' font-family='Arial Black' fill='%23FF5A1F' font-weight='900'>N</text></svg>">
<title>Рћ РїСЂРѕРµРєС‚Рµ New Generation English</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Unbounded:wght@500;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="preload" href="./system.css" as="style">
<script>
  function toggleTheme() {
    document.body.classList.toggle("light");
    localStorage.setItem("nge-theme", document.body.classList.contains("light") ? "light" : "dark");
    const btn = document.querySelector(".control-btn");
    if (btn) btn.textContent = document.body.classList.contains("light") ? "вЂ" : "вѕ";
  }
  function toggleLang() {
    const cur = document.documentElement.getAttribute("lang") || "ru";
    const next = cur === "ru" ? "en" : "ru";
    document.documentElement.setAttribute("lang", next);
    document.querySelectorAll("[data-ru]").forEach(el => {
      const val = el.getAttribute("data-" + next);
      if (val) el.textContent = val;
    });
    const btn = document.getElementById("langBtn");
    if (btn) btn.textContent = next.toUpperCase();
    localStorage.setItem("nge-lang", next);
  }

  function updateExperienceCounter() {
    const el = document.getElementById("expCounter");
    if (!el) return;

    // Teacher experience counter: since 2009-09-01.
    const start = new Date(2009, 8, 1); // months are 0-based
    const now = new Date();

    let years = now.getFullYear() - start.getFullYear();
    let months = now.getMonth() - start.getMonth();
    let days = now.getDate() - start.getDate();

    if (days < 0) {
      months -= 1;
      const prevMonthDays = new Date(now.getFullYear(), now.getMonth(), 0).getDate();
      days += prevMonthDays;
    }
    if (months < 0) {
      years -= 1;
      months += 12;
    }

    el.textContent = years + "+";
    const lang = document.documentElement.getAttribute("lang") || "ru";
    el.title = lang === "en"
      ? `${years}y ${months}m ${days}d since Sep 1, 2009`
      : `${years} Р»РµС‚ ${months} РјРµСЃ ${days} РґРЅ СЃ 1 СЃРµРЅС‚СЏР±СЂСЏ 2009`;
  }

  function updateExperienceTicker() {
    const ticker = document.getElementById("expTicker");
    if (!ticker) return;

    const start = new Date(2009, 8, 1);
    const now = new Date();

    let years = now.getFullYear() - start.getFullYear();
    let months = now.getMonth() - start.getMonth();
    let days = now.getDate() - start.getDate();

    if (days < 0) {
      months -= 1;
      const prevMonthDays = new Date(now.getFullYear(), now.getMonth(), 0).getDate();
      days += prevMonthDays;
    }
    if (months < 0) {
      years -= 1;
      months += 12;
    }

    const pad2 = (n) => String(n).padStart(2, "0");
    const hh = pad2(now.getHours());
    const mm = pad2(now.getMinutes());
    const ss = pad2(now.getSeconds());
    const digits = `${years}y ${pad2(months)}m ${pad2(days)}d ${hh}:${mm}:${ss}`;

    const lang = document.documentElement.getAttribute("lang") || "ru";
    ticker.textContent = (lang === "en" ? "EXP: " : "РЎРўРђР–: ") + digits;
    ticker.title = lang === "en"
      ? `${years}y ${months}m ${days}d since Sep 1, 2009`
      : `${years} Р»РµС‚ ${months} РјРµСЃ ${days} РґРЅ СЃ 1 СЃРµРЅС‚СЏР±СЂСЏ 2009`;
  }
  function markActiveNav() {
    const page = document.body.dataset.page;
    if (!page) return;
    document.querySelectorAll(".topnav-link[data-nav]").forEach(l => {
      l.classList.toggle("active", l.dataset.nav === page);
    });
  }

  document.addEventListener("DOMContentLoaded", function restore() {
    try {
      const savedLang = localStorage.getItem("nge-lang");
      if (savedLang === "en") toggleLang();
    } catch (e) {}

    markActiveNav();
    updateExperienceCounter();
    updateExperienceTicker();
    // About-me ticker: update once per second without touching the hero counter.
    setInterval(updateExperienceTicker, 1000);
  });
</script>
<style>
/* ============================================================
   TOKENS вЂ” STRICT SYSTEM FROM INDEX.HTML
   ============================================================ */




* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
button { font: inherit; }
::selection { background: var(--accent); color: #000; }

/* ============================================================
   TOPBAR (СЃРѕС…СЂР°РЅРµРЅ РёР· about)
   ============================================================ */
/* ============================================================
   SECTION PRIMITIVES
   ============================================================ */
.sect-head {
  display: grid; grid-template-columns: 140px minmax(0, 1fr);
  gap: 40px; margin-bottom: 48px;
  align-items: end;
}
.sect-index {
  font-family: var(--display);
  font-size: 72px; font-weight: 900; line-height: 0.9;
  letter-spacing: -0.05em;
  color: var(--text);
  -webkit-text-stroke: 1px var(--text);
  color: transparent;
}
.sect-index small {
  display: block;
  font-family: var(--mono); font-size: 10px; font-weight: 500;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--text-3);
  -webkit-text-stroke: 0;
  color: var(--text-3);
  margin-top: 8px;
}
.sect-title {
  font-size: clamp(1.75rem, 3.2vw, 2.75rem);
}
.sect-title .accent { color: var(--accent); }
.sect-eyebrow {
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 14px;
}
.section { padding: 80px 24px; max-width: 1240px; margin: 0 auto; }
.dash {
  height: 1px;
  background-image: linear-gradient(to right, var(--line) 50%, transparent 50%);
  background-size: 12px 1px;
  background-repeat: repeat-x;
  max-width: 1240px; margin: 0 auto;
}

/* ============================================================
   ECOSYSTEM BUTTON STRIP (top shortcuts)
   ============================================================ */
.ecosystem-strip {
  max-width: 1240px;
  margin: 18px auto 0;
  padding: 0 24px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}
.eco-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 16px;
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0) 60%),
    rgba(0,0,0,0.78);
  color: var(--text);
  border: 1px solid rgba(255,90,31,0.55);
  border-color: color-mix(in srgb, var(--accent) 70%, transparent);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.06),
    0 0 0 1px color-mix(in srgb, var(--accent) 18%, transparent),
    0 10px 26px rgba(0,0,0,0.55);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  text-decoration: none;
  transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  min-height: 40px;
}
.eco-btn:hover {
  transform: translateY(-1px);
  border-color: color-mix(in srgb, var(--accent) 86%, transparent);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.08),
    0 0 0 1px color-mix(in srgb, var(--accent) 26%, transparent),
    0 0 22px color-mix(in srgb, var(--accent) 18%, transparent),
    0 12px 30px rgba(0,0,0,0.6);
}
.eco-btn:active { transform: translateY(0); }
.eco-btn:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 3px color-mix(in srgb, var(--accent) 28%, transparent),
    inset 0 1px 0 rgba(255,255,255,0.08),
    0 0 0 1px color-mix(in srgb, var(--accent) 26%, transparent),
    0 12px 30px rgba(0,0,0,0.6);
}

/* Light theme: avoid dark pills on cream background */
body.light .eco-btn {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.85), rgba(255,255,255,0) 60%),
    rgba(255,255,255,0.92);
  border-color: color-mix(in srgb, var(--accent) 42%, rgba(0,0,0,0.12));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.7),
    0 0 0 1px rgba(0,0,0,0.02),
    0 14px 30px rgba(16, 12, 8, 0.14);
}
body.light .eco-btn:hover {
  border-color: color-mix(in srgb, var(--accent) 60%, rgba(0,0,0,0.10));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.78),
    0 0 0 1px rgba(0,0,0,0.03),
    0 0 22px color-mix(in srgb, var(--accent) 14%, transparent),
    0 16px 34px rgba(16, 12, 8, 0.16);
}
body.light .eco-btn:focus-visible {
  box-shadow:
    0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent),
    inset 0 1px 0 rgba(255,255,255,0.78),
    0 0 0 1px rgba(0,0,0,0.03),
    0 16px 34px rgba(16, 12, 8, 0.16);
}
.eco-btn-label {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.eco-btn-arrow {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 700;
  color: var(--accent);
  opacity: 0.9;
}
@media (max-width: 980px) {
  .ecosystem-strip { grid-template-columns: 1fr; }
  .eco-btn { justify-content: center; }
  .eco-btn-arrow { display: none; }
}

.eco-btn.is-active {
  border-color: color-mix(in srgb, var(--accent) 86%, transparent);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.08),
    0 0 0 1px color-mix(in srgb, var(--accent) 26%, transparent),
    0 0 22px color-mix(in srgb, var(--accent) 18%, transparent),
    0 12px 30px rgba(0,0,0,0.6);
}
body.light .eco-btn.is-active {
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.78),
    0 0 0 1px rgba(0,0,0,0.03),
    0 0 22px color-mix(in srgb, var(--accent) 14%, transparent),
    0 16px 34px rgba(16, 12, 8, 0.16);
}

.eco-cabinets {
  padding-top: 34px;
  padding-bottom: 10px;
  scroll-margin-top: 86px;
}
.eco-cabinets .sect-head { position: relative; margin-bottom: 18px; }
.eco-cabinets-close {
  position: absolute;
  top: 0;
  right: 0;
  width: 36px;
  height: 36px;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--bg-2) 70%, transparent);
  color: var(--text);
  cursor: pointer;
  font-size: 22px;
  line-height: 1;
}
body.light .eco-cabinets-close {
  background: rgba(255,255,255,0.9);
  border-color: rgba(0,0,0,0.10);
  color: var(--text);
}

.cabinet-card.is-active {
  border-color: color-mix(in srgb, var(--accent) 70%, transparent);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.06),
    0 0 0 1px color-mix(in srgb, var(--accent) 18%, transparent),
    0 16px 34px rgba(0,0,0,0.55);
}
body.light .cabinet-card.is-active {
  border-color: color-mix(in srgb, var(--accent) 55%, rgba(0,0,0,0.10));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.7),
    0 0 0 1px rgba(0,0,0,0.03),
    0 0 22px color-mix(in srgb, var(--accent) 12%, transparent),
    0 18px 38px rgba(16, 12, 8, 0.14);
}

/* ============================================================
   HERO (РїРµСЂРµРґРµР»Р°РЅ РїРѕРґ СЃРёСЃС‚РµРјСѓ)
   ============================================================ */
/* ============================================================
   ABOUT GRID (2 РєРѕР»РѕРЅРєРё С‚РµРєСЃС‚Р°)
   ============================================================ */
.about-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 40px;
}
.about-text p {
  margin-bottom: 18px;
  font-size: 16px; line-height: 1.65;
  color: var(--text-2);
}
.about-text p:last-child { margin-bottom: 0; }
.about-text p strong { color: var(--text); font-weight: 600; }

/* ============================================================
   CABINET GRID
   ============================================================ */
.cabinet-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.cabinet-card {
  position: relative;
  padding: 28px 24px 24px;
  display: block;
  text-decoration: none;
  color: inherit;
}
.cabinet-num {
  position: absolute; top: 20px; right: 20px;
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.14em; color: var(--text-3);
}
.cabinet-title {
  font-size: 22px;
  margin-bottom: 16px;
}
.cabinet-list {
  list-style: none; margin-bottom: 20px;
}
.cabinet-list li {
  position: relative; padding-left: 20px;
  font-size: 14px; color: var(--text-2); line-height: 1.6;
  margin-bottom: 8px;
}
.cabinet-list li::before {
  content: "в†’"; position: absolute; left: 0;
  font-family: var(--mono); color: var(--accent); font-weight: 700;
}
.cabinet-status {
  display: block;
  width: fit-content;
  padding: 6px 12px;
  border: 1px solid var(--line);
  color: var(--text-3);
  font-family: var(--mono); font-size: 10px;
  letter-spacing: 0.1em; text-transform: uppercase;
  border-radius: 4px;
  margin: 14px auto 0;
}

/* Cabinets emphasis (about page only) */
.cabinet-card::before {
  content: "";
  position: absolute;
  left: 16px;
  right: 16px;
  top: 16px;
  height: 1px;
  background: color-mix(in srgb, var(--accent) 55%, transparent);
  opacity: .85;
  pointer-events: none;
}
.cabinet-lead {
  max-width: 980px;
  margin: 0 auto 28px;
  text-align: center;
  font-family: inherit;
  font-size: 15px;
  line-height: 1.7;
  letter-spacing: 0;
  text-transform: none;
  color: var(--text-2);
}

/* Experience counter */

/* Neuro-school clarification note (Section 01) */
.neuro-definition {
  position: relative;
  padding: 28px;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(255, 90, 31, 0.10), rgba(255, 90, 31, 0.03));
  border: 1px solid rgba(255, 90, 31, 0.25);
  box-shadow:
    0 10px 30px rgba(0, 0, 0, 0.35),
    inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  margin: 24px 0;
  transition: transform 0.2s ease, border-color 0.2s ease;
}
.neuro-definition p { margin: 0; }
.neuro-definition .note { margin-top: 10px; color: var(--text-2); }
.neuro-definition strong { color: var(--text); }

.neuro-definition::before {
  content: "";
  position: absolute;
  top: 0;
  left: 20px;
  right: 20px;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--accent), transparent);
  opacity: 0.6;
}

.neuro-definition .document-heading {
  font-size: 11px;
  letter-spacing: 0.18em;
  margin-bottom: 14px;
}

.neuro-definition:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 90, 31, 0.4);
}

/* Dark theme only: IMPORTANT (вЂњР’РђР–РќРћвЂќ) block styling */
body:not(.light) .important-box,
body:not(.light) .neuro-definition {
  background: linear-gradient(180deg, rgba(255, 90, 31, 0.15), rgba(255, 90, 31, 0.05));
  border: 1px solid rgba(255, 90, 31, 0.3);
  box-shadow:
    0 0 0 1px rgba(255, 90, 31, 0.2),
    0 12px 40px rgba(255, 90, 31, 0.1);
}

body:not(.light) .important-box p,
body:not(.light) .neuro-definition .note {
  color: rgba(255, 255, 255, 0.85);
}

body:not(.light) .important-box strong,
body:not(.light) .neuro-definition strong {
  color: #ffffff;
  font-weight: 600;
}

/* ============================================================
   ARTICLES GRID
   ============================================================ */
.articles-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
.article-card {
  padding: 40px 36px;
}
.article-card h3 {
  font-size: 26px;
  margin-bottom: 20px;
}
.article-card p {
  font-size: 17px; line-height: 1.65;
  color: var(--text-2);
  margin-bottom: 16px;
}
.article-card p:last-child { margin-bottom: 0; }
.bio-layout {
  display: grid;
  grid-template-columns: minmax(320px, 420px) 1fr;
  gap: 32px;
  align-items: center;
  max-width: 1240px;
  margin: 0 auto 28px;
}
.document-box {
  margin-top: 24px;
  padding: 22px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
}
.document-heading {
  font-family: var(--mono); font-size: 12px;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 12px;
}
.doc-list {
  list-style: none; margin-bottom: 12px;
}
.doc-list li {
  position: relative; padding-left: 18px;
  font-size: 14px; color: var(--text-2); line-height: 1.55;
  margin-bottom: 6px;
}
.doc-list li::before {
  content: "вЂў"; position: absolute; left: 0;
  color: var(--accent);
}
.document-note {
  font-size: 13px; color: var(--text-3);
  font-family: var(--mono);
}
.note {
  color: var(--text-3);
  font-size: 14px;
}

/* ============================================================
   CTA
   ============================================================ */
.cta {
  padding: 96px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  text-align: center;
}
.cta-head {
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 22px;
  display: flex; align-items: center; gap: 14px;
  justify-content: center;
}
.cta-head::before,
.cta-head::after { content: ""; flex: 1; height: 1px; background: var(--line); }
.cta h2 {
  font-size: clamp(2.5rem, 6vw, 5rem);
  max-width: 1000px;
  margin: 0 auto 30px;
}
.cta h2 .accent { color: var(--accent); }
.cta p {
  max-width: 620px;
  margin: 0 auto 36px;
  font-size: 17px; line-height: 1.55;
  color: var(--text-2);
}

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
  max-width: 1240px; margin: 0 auto;
  padding: 40px 24px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; flex-wrap: wrap;
  border-top: 1px solid var(--line);
}
.footer-copy {
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.08em; color: var(--text-3);
}
.footer-copy a { color: var(--text-2); }
.footer-copy a:hover { color: var(--accent); }
.footer-links { display: flex; gap: 4px; flex-wrap: wrap; }
.footer-link {
  padding: 6px 12px; border-radius: 6px;
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-3); transition: all .15s;
}
.footer-link:hover { color: var(--text); background: color-mix(in srgb, var(--text) 8%, transparent); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1024px) {
  .cabinet-grid, .articles-grid { grid-template-columns: 1fr; }
  .sect-head { grid-template-columns: 1fr; gap: 24px; }
  .about-grid { grid-template-columns: 1fr; gap: 24px; }
  .bio-layout { grid-template-columns: 1fr; }
  .bio-photo { max-width: 360px; margin: 0 auto; }
}
@media (max-width: 768px) {
  .cta { padding: 56px 0; }
}
</style>
